<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log In | BoliBazar | Factory to Shop</title>
    
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#001f3f',
                        'secondary-dark': '#001021',
                    }
                }
            }
        }
    </script>
    <style>
        .hero-gradient {
            background: linear-gradient(135deg, #001f3f 0%, #001021 100%);
        }
        .feature-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 16px;
        }
        .login-container {
            min-height: 100vh;
        }
    </style>
</head>
<body class="bg-gray-50 font-sans">

    <div class="flex flex-col md:flex-row h-screen overflow-hidden">
        
        <!-- Left Side: Branding & Info -->
        <div class="md:w-1/2 lg:w-3/5 hero-gradient text-white p-8 lg:p-16 flex flex-col justify-between relative overflow-y-auto">
            <!-- Background Decoration -->
            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full -mr-64 -mt-64"></div>
            
            <div class="z-10">
                <!-- Logo -->
                <div class="flex items-center space-x-3 mb-16">
                    <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg">
                        <i class="fas fa-gavel text-2xl"></i>
                    </div>
                    <div>
                        <h1 class="text-2xl font-black tracking-tighter uppercase leading-none">BoliBazar</h1>
                        <p class="text-[10px] font-bold text-primary tracking-widest uppercase text-right">Factory to Retailer Platform</p>
                    </div>
                </div>

                <h2 class="text-4xl lg:text-6xl font-black mb-6 font-heading leading-tight underline decoration-primary decoration-4 underline-offset-8 text-white">
                    Direct Sourcing, <br><span class="text-primary italic">Better Pricing.</span>
                </h2>
                <p class="text-lg text-blue-100 max-w-md mb-8 font-medium">
                    Log in to access exclusive factory-direct auctions and secure high-margin inventory for your shop.
                </p>

                <!-- Trust Points (Synced with Register) -->
                <div class="space-y-6 mb-12">
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 backdrop-blur-md border border-white/20">
                            <i class="fas fa-industry text-primary text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg">Direct from Factory</h4>
                            <p class="text-sm text-blue-200">Bypass 3-4 layers of wholesalers. Buy inventory at the price they buy.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 backdrop-blur-md border border-white/20">
                            <i class="fas fa-shield-alt text-primary text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg">Verified Bidding</h4>
                            <p class="text-sm text-blue-200">Only genuine manufacturers list their stock. Secured with 10% token protection.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 backdrop-blur-md border border-white/20">
                            <i class="fas fa-truck-loading text-primary text-xl"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg">Doorstep Delivery</h4>
                            <p class="text-sm text-blue-200">Across 150+ cities in India. We handle the logistics while you run your business.</p>
                        </div>
                    </div>
                </div>

                <!-- Trust Stats -->
                <div class="flex items-center space-x-6 mb-12 border-t border-white/10 pt-8">
                    <div class="flex -space-x-2">
                        <div class="w-8 h-8 rounded-full border border-secondary bg-gray-600 transition hover:z-10 hover:scale-110"></div>
                        <div class="w-8 h-8 rounded-full border border-secondary bg-gray-500 transition hover:z-10 hover:scale-110"></div>
                        <div class="w-8 h-8 rounded-full border border-secondary bg-gray-400 transition hover:z-10 hover:scale-110"></div>
                    </div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-none">12,000+ Active Retailers</p>
                </div>
            </div>

            <!-- Policy Alert -->
            <div class="z-10 bg-white/5 border border-white/10 p-6 rounded-3xl flex items-start space-x-4">
                <div class="w-10 h-10 bg-yellow-400/20 text-yellow-400 rounded-xl flex flex-shrink-0 items-center justify-center text-xl">
                    <i class="fas fa-wallet"></i>
                </div>
                <div>
                    <h5 class="font-black text-xs uppercase mb-1 tracking-wider">How the Token System works?</h5>
                    <p class="text-[10px] text-gray-400 font-medium leading-relaxed">
                        Pay only a 10% advance token to confirm your booking. Full payment qualifies for FREE delivery. Cash on Delivery (COD) available with a 10% extra delivery charge on the balance.
                    </p>
                </div>
            </div>
        </div>

        <!-- Right Side: Login Form -->
        <div class="md:w-1/2 lg:w-2/5 bg-white p-8 lg:p-16 flex flex-col justify-start items-center overflow-y-auto">
            <div class="w-full max-w-sm">
                
                <!-- Toggle Tabs -->
                <div class="bg-gray-100 p-1 rounded-2xl flex mb-12">
                    <button class="flex-1 py-3 text-sm font-bold rounded-xl bg-white shadow-sm text-primary">Login</button>
                    <a href="/register" class="flex-1 py-3 text-sm font-bold rounded-xl text-gray-400 hover:text-secondary transition text-center">Register</a>
                </div>

                <!-- Welcome Text -->
                <div class="mb-10">
                    <h3 class="text-4xl font-black mb-2 font-heading tracking-tight">Welcome back!</h3>
                    <p class="text-gray-400 text-sm font-medium">Please enter your details to login.</p>
                </div>

                <% if (error) { %>
                    <div class="bg-red-50 text-red-600 text-xs font-bold p-4 rounded-xl mb-6 flex items-center">
                        <i class="fas fa-exclamation-circle mr-2"></i> <%= error %>
                    </div>
                <% } %>

                <!-- Form -->
                <form action="/login" method="POST" class="space-y-6">
                    <div>
                        <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Mobile Number</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-300">
                                <i class="fas fa-phone"></i>
                            </span>
                            <input type="tel" id="phone" name="phone" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-12 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="9876543210">
                        </div>
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Password</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-300">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input type="password" id="password" name="password" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-12 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="••••••••">
                            <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-300 hover:text-secondary">
                                <i class="far fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="flex items-center justify-between text-xs font-bold">
                        <label class="flex items-center space-x-2 cursor-pointer">
                            <input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary">
                            <span class="text-gray-500">Remember me</span>
                        </label>
                        <a href="#" class="text-primary hover:underline">Forgot password?</a>
                    </div>

                    <button type="submit" class="w-full btn-primary py-4 rounded-2xl text-sm font-black uppercase tracking-[0.2em] shadow-xl shadow-red-100 flex items-center justify-center group">
                        Sign In Now <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition"></i>
                    </button>
                </form>

                <!-- Demo Credentials Section -->
                <div class="mt-12 p-6 bg-yellow-50 rounded-3xl border border-yellow-100">
                    <div class="flex items-center space-x-2 text-[10px] font-black text-yellow-600 uppercase mb-4 tracking-widest">
                        <i class="fas fa-key"></i>
                        <span>Demo Credentials — Click to autofill</span>
                    </div>
                    <div class="space-y-3">
                        <button type="button" onclick="autofill('9876543210', 'retailer123')" class="w-full bg-white p-4 rounded-xl border border-yellow-200 text-left hover:border-yellow-400 transition">
                            <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Retailer</p>
                            <p class="text-xs font-bold text-secondary">9876543210 / retailer123</p>
                        </button>
                        <button type="button" onclick="autofill('9999999999', 'admin123')" class="w-full bg-white p-4 rounded-xl border border-yellow-200 text-left hover:border-yellow-400 transition">
                            <p class="text-[10px] font-black text-gray-400 uppercase mb-1">Administrator</p>
                            <p class="text-xs font-bold text-secondary">9999999999 / admin123</p>
                        </button>
                    </div>
                </div>

                <p class="mt-12 text-center text-xs font-bold text-gray-400">
                    Need a new account? <a href="/register" class="text-primary hover:underline">Create Account</a>
                </p>
                <div class="mt-6 pt-6 border-t border-gray-50 text-center">
                    <p class="text-[10px] font-black text-gray-300 uppercase tracking-widest mb-2">Are you a Factory / Vendor?</p>
                    <a href="/manufacturer-register" class="text-[10px] font-black text-secondary hover:text-primary transition uppercase tracking-widest flex items-center justify-center gap-2">
                        <i class="fas fa-industry"></i>
                        Register as Manufacturer
                    </a>
                </div>
            </div>
        </div>

    </div>

    <script>
        function autofill(phone, pass) {
            document.getElementById('phone').value = phone;
            document.getElementById('password').value = pass;
        }
    </script>

</body>
</html>
