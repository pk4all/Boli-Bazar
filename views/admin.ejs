<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Command Center | Boli Bazar</title>
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#001f3f',
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .sidebar-link.active {
            background: #d90429;
            color: white;
        }
        .admin-section {
            display: none;
        }
        .admin-section.active {
            display: block;
        }
    </style>
</head>
<body class="bg-[#f8fafc] text-slate-900 font-sans">

    <div class="flex h-screen overflow-hidden">
        
        <!-- Sidebar -->
        <aside class="w-64 bg-slate-900 text-white flex-shrink-0 flex flex-col">
            <div class="p-6 border-b border-white/5">
                <a href="/" class="text-xl font-black uppercase tracking-tighter">Boli<span class="text-primary">Bazar</span></a>
                <p class="text-[10px] text-slate-500 font-bold uppercase mt-1">Command Center</p>
            </div>
            <nav class="flex-grow p-4 space-y-2">
                <button onclick="showSection('overview')" class="sidebar-link active w-full flex items-center space-x-3 p-3 rounded-xl text-sm font-bold transition">
                    <i class="fas fa-chart-pie w-5"></i>
                    <span>Overview</span>
                </button>
                <button onclick="showSection('lots')" class="sidebar-link w-full flex items-center space-x-3 p-3 text-slate-400 hover:bg-white/5 rounded-xl text-sm font-bold transition">
                    <i class="fas fa-boxes w-5"></i>
                    <span>Manage Lots</span>
                </button>
                <button onclick="showSection('retailers')" class="sidebar-link w-full flex items-center space-x-3 p-3 text-slate-400 hover:bg-white/5 rounded-xl text-sm font-bold transition">
                    <i class="fas fa-users w-5"></i>
                    <span>Retailer List</span>
                </button>
                <button onclick="showSection('orders')" class="sidebar-link w-full flex items-center space-x-3 p-3 text-slate-400 hover:bg-white/5 rounded-xl text-sm font-bold transition">
                    <i class="fas fa-shopping-bag w-5"></i>
                    <span>Winning Orders</span>
                </button>
                <button onclick="showSection('media')" class="sidebar-link w-full flex items-center space-x-3 p-3 text-slate-400 hover:bg-white/5 rounded-xl text-sm font-bold transition">
                    <i class="fas fa-photo-video w-5"></i>
                    <span>Media & Banners</span>
                </button>
                <button onclick="showSection('rewards')" class="sidebar-link w-full flex items-center space-x-3 p-3 text-slate-400 hover:bg-white/5 rounded-xl text-sm font-bold transition">
                    <i class="fas fa-trophy w-5"></i>
                    <span>Rewards</span>
                </button>
                <button onclick="showSection('hallOfFame')" class="sidebar-link w-full flex items-center space-x-3 p-3 text-slate-400 hover:bg-white/5 rounded-xl text-sm font-bold transition">
                    <i class="fas fa-history w-5"></i>
                    <span>Hall of Fame Archive</span>
                </button>
            </nav>
            <div class="p-6 border-t border-white/5">
                <a href="/logout" class="text-xs font-bold text-red-500 uppercase flex items-center space-x-2">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout Admin</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-grow overflow-y-auto bg-slate-50">
            
            <!-- OVERVIEW SECTION -->
            <div id="overview" class="admin-section active p-8">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
                    <h1 class="text-3xl font-black">System <span class="text-red-600">Overview</span></h1>
                    
                    <!-- Date Filter Form -->
                    <form action="/admin" method="GET" class="flex flex-wrap items-center gap-3 bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
                        <div class="flex items-center space-x-2 px-3 border-r border-slate-100">
                            <i class="fas fa-calendar-alt text-slate-400 text-xs"></i>
                            <input type="date" name="startDate" value="<%= startDate %>" class="text-xs font-bold focus:outline-none bg-transparent">
                        </div>
                        <div class="flex items-center space-x-2 px-3">
                            <input type="date" name="endDate" value="<%= endDate %>" class="text-xs font-bold focus:outline-none bg-transparent">
                        </div>
                        <button type="submit" class="bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-xl hover:bg-primary transition">
                            Apply Filter
                        </button>
                        <% if (startDate || endDate) { %>
                            <a href="/admin" class="text-[10px] font-black uppercase text-slate-400 hover:text-red-500 underline">Clear</a>
                        <% } %>
                    </form>

                    <div class="flex items-center space-x-4 bg-white p-3 rounded-2xl border border-slate-200">
                        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                        <p class="text-xs font-black uppercase tracking-widest text-slate-400">Live Status: Operational</p>
                    </div>
                </div>

                <!-- Financial Overview: Revenue Metrics -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-xl relative overflow-hidden group">
                        <div class="absolute -top-10 -right-10 w-40 h-40 bg-white/5 rounded-full blur-3xl group-hover:bg-primary/10 transition duration-500"></div>
                        <div class="relative z-10">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-2 flex items-center gap-2">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                                Lifetime Collection
                            </p>
                            <h3 class="text-3xl font-black text-white">₹<%= totalRevenue.toLocaleString() %></h3>
                            <p class="text-[10px] font-bold text-slate-500 mt-4 uppercase tracking-widest">Total amount received (Paid Now + Full)</p>
                        </div>
                    </div>
                    <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200 relative overflow-hidden group">
                        <div class="relative z-10">
                            <p class="text-[10px] font-black text-green-500 uppercase tracking-[0.2em] mb-2 flex items-center gap-2">
                                <i class="fas fa-calendar-check text-[8px]"></i>
                                Today's Collection
                            </p>
                            <h3 class="text-3xl font-black text-slate-800">₹<%= todayRevenue.toLocaleString() %></h3>
                            <div class="flex items-center gap-2 mt-4">
                                <span class="px-2 py-0.5 bg-green-50 text-green-600 text-[8px] font-black rounded uppercase tracking-tighter border border-green-100">+ REAL-TIME</span>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Updated: <%= new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-200 relative overflow-hidden group">
                        <div class="relative z-10">
                            <p class="text-[10px] font-black text-orange-500 uppercase tracking-[0.2em] mb-2 flex items-center gap-2">
                                <i class="fas fa-hand-holding-dollar text-[8px]"></i>
                                Total COD Pending
                            </p>
                            <h3 class="text-3xl font-black text-slate-800">₹<%= pendingCod.toLocaleString() %></h3>
                            <p class="text-[10px] font-bold text-slate-400 mt-4 uppercase tracking-widest">Balance yet to be collected from retailers</p>
                        </div>
                    </div>
                </div>

                <!-- Stats Grid: Operational Metrics -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
                    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase mb-0.5">Total Orders</p>
                                <p class="text-2xl font-black text-slate-800"><%= orders.length %></p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-purple-50 text-purple-500 rounded-2xl flex items-center justify-center">
                                <i class="fas fa-user-friends"></i>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase mb-0.5">Retailers</p>
                                <p class="text-2xl font-black text-slate-800"><%= retailerCount %></p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-green-50 text-green-500 rounded-2xl flex items-center justify-center">
                                <i class="fas fa-bolt"></i>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase mb-0.5">Live Lots</p>
                                <p class="text-2xl font-black text-green-600"><%= liveProductsCount %></p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-orange-50 text-orange-500 rounded-2xl flex items-center justify-center">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase mb-0.5">Upcoming</p>
                                <p class="text-2xl font-black text-orange-500"><%= upcomingProductsCount %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sales Performance Trend -->
                <div class="bg-white p-8 rounded-[40px] shadow-sm border border-slate-200 mb-12">
                    <div class="flex justify-between items-center mb-8">
                        <div class="flex flex-col">
                            <h2 class="text-2xl font-black text-slate-800">Sales <span class="text-primary">Performance</span></h2>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">
                                <%= (startDate || endDate) ? 'Filtered Range Trend' : 'Monthly Collection Trend (Current Month)' %>
                            </p>
                        </div>
                        <div class="flex items-center space-x-2">
                             <div class="px-3 py-1 bg-green-50 border border-green-100 rounded-lg">
                                <p class="text-[10px] font-black text-green-600 italic">Live Trends ↗</p>
                             </div>
                        </div>
                    </div>
                    <div class="h-[300px] w-full">
                        <canvas id="salesChart"></canvas>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                    <!-- Create New Lot -->
                    <!-- Create New Lot (Advanced Form) -->
                    <section class="bg-white p-8 rounded-[40px] shadow-sm border border-slate-200">
                        <h2 class="text-xl font-black mb-6">Launch New <span class="text-primary">Auction</span></h2>
                        <form action="/admin/add-product" method="POST" enctype="multipart/form-data" class="space-y-6">
                            <!-- Basic Details -->
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="md:col-span-2">
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Product Title</label>
                                    <input type="text" name="title" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. Basmati Rice Premium 50kg">
                                </div>
                                
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Starting Price (₹)</label>
                                    <input type="number" name="initialPrice" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                </div>
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Lot Size / Units</label>
                                    <input type="number" name="lotSize" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                </div>

                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Min Order Qty (MOQ)</label>
                                    <input type="number" name="moq" value="1" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                </div>
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Price Hike (%) per Bid</label>
                                    <input type="number" name="hikePercentage" value="0" step="0.1" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                </div>

                                <div class="md:col-span-1">
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Category</label>
                                    <select name="category" onchange="handleCategoryChange(this.value)" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                        <% categories.forEach(cat => { %>
                                            <option value="<%= cat %>"><%= cat %></option>
                                        <% }) %>
                                        <option value="other" class="font-black text-red-600">+ New Category...</option>
                                    </select>
                                    <!-- Dynamic New Category Input -->
                                    <div id="newCategoryWrapper" class="mt-3 hidden">
                                        <input type="text" name="newCategory" placeholder="Enter New Category Name" class="w-full bg-red-50 border border-red-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-red-500 font-bold placeholder:text-red-300">
                                    </div>
                                </div>

                                <script>
                                    const presets = {
                                        'Clothing': ['Material', 'Size Range', 'Gender', 'Color', 'GSM', 'Brand Origin'],
                                        'Electronics': ['Battery', 'Screen Size', 'Processor', 'RAM', 'Storage', 'Warranty'],
                                        'Grocery': ['Expiry Date', 'Net Weight', 'Packaging', 'Origin', 'FSSAI License'],
                                        'Oils': ['Purity', 'Grade', 'Packaging Type', 'Shelf Life'],
                                        'Sugar': ['Grade', 'ICUMSA', 'Origin', 'Packaging'],
                                        'Grains': ['Variety', 'Moisture', 'Broken %', 'Sorting Type'],
                                        'General': ['Weight', 'Dimensions', 'Warranty', 'Material', 'Color']
                                    };

                                    function handleCategoryChange(val) {
                                        // Handle New Category Toggle
                                        const wrapper = document.getElementById('newCategoryWrapper');
                                        if (val === 'other') {
                                            wrapper.classList.remove('hidden');
                                            wrapper.querySelector('input').focus();
                                        } else {
                                            wrapper.classList.add('hidden');
                                        }

                                        // Update Presets
                                        updatePresets(val);
                                    }

                                    function updatePresets(cat) {
                                        const container = document.getElementById('spec-presets');
                                        const catLabel = document.getElementById('current-category-name');
                                        catLabel.innerText = cat.toUpperCase();
                                        
                                        // Clear current presets (keep the label)
                                        const labelHtml = `<p class="text-[9px] font-bold text-gray-400 w-full mb-1">SUGGESTIONS FOR <span id="current-category-name" class="text-primary font-black">${cat.toUpperCase()}</span>:</p>`;
                                        container.innerHTML = labelHtml;

                                        const items = presets[cat] || presets['General'];
                                        items.forEach(item => {
                                            const btn = document.createElement('button');
                                            btn.type = 'button';
                                            btn.className = 'px-3 py-1 bg-white border border-slate-100 rounded-full text-[9px] font-black text-slate-400 hover:border-primary hover:text-primary transition';
                                            btn.innerText = `+ ${item}`;
                                            btn.onclick = () => addSpecRow(item);
                                            container.appendChild(btn);
                                        });
                                    }

                                    function addSpecRow(key = '', value = '') {
                                        const container = document.getElementById('spec-container');
                                        const row = document.createElement('div');
                                        row.className = 'flex items-center gap-3 spec-row animate-in fade-in slide-in-from-left-2 duration-300';
                                        row.innerHTML = `
                                            <input type="text" name="spec_keys[]" value="${key}" placeholder="e.g. ${key || 'Weight'}" class="w-1/3 bg-slate-50 border border-slate-100 rounded-xl px-4 py-2 text-xs focus:outline-none focus:border-primary font-bold">
                                            <input type="text" name="spec_values[]" value="${value}" placeholder="e.g. Value" class="flex-grow bg-slate-50 border border-slate-100 rounded-xl px-4 py-2 text-xs focus:outline-none focus:border-primary">
                                            <button type="button" onclick="this.parentElement.remove()" class="text-slate-300 hover:text-red-500 transition">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        `;
                                        container.appendChild(row);
                                        if (!key) row.querySelector('input').focus();
                                    }

                                    // Initialize with General presets
                                    document.addEventListener('DOMContentLoaded', () => {
                                        updatePresets('General');
                                    });

                                    function previewImage(input) {
                                        const file = input.files[0];
                                        const container = input.nextElementSibling;
                                        if (file) {
                                            const reader = new FileReader();
                                            reader.onload = function(e) {
                                                container.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover rounded-2xl">`;
                                                container.classList.remove('border-dashed');
                                                container.classList.add('border-solid', 'border-primary/30');
                                            }
                                            reader.readAsDataURL(file);
                                        }
                                    }
                                </script>
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Execution Status</label>
                                    <select name="status" id="auctionStatus" onchange="toggleScheduling(this.value)" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                        <option value="Live">Live (Start Now)</option>
                                        <option value="Upcoming">Upcoming (Schedule)</option>
                                    </select>
                                </div>

                                <!-- Dynamic Start Schedule -->
                                <div id="startSchedule" class="md:col-span-2 grid grid-cols-2 gap-6 hidden">
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Auction Start Date</label>
                                        <input type="date" name="startDate" class="w-full bg-blue-50 border border-blue-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-blue-500">
                                    </div>
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Auction Start Time</label>
                                        <input type="time" name="startTime" class="w-full bg-blue-50 border border-blue-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-blue-500">
                                    </div>
                                </div>

                                <div class="md:col-span-1">
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Auction End Date</label>
                                    <input type="date" name="endDate" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                </div>
                                <div class="md:col-span-1">
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Auction End Time</label>
                                    <input type="time" name="endTime" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary">
                                </div>

                                <script>
                                    function toggleScheduling(val) {
                                        const scheduleDiv = document.getElementById('startSchedule');
                                        if (val === 'Upcoming') {
                                            scheduleDiv.classList.remove('hidden');
                                            scheduleDiv.querySelectorAll('input').forEach(i => i.required = true);
                                        } else {
                                            scheduleDiv.classList.add('hidden');
                                            scheduleDiv.querySelectorAll('input').forEach(i => i.required = false);
                                        }
                                    }
                                </script>
                            </div>

                            <!-- Media Section -->
                            <div class="space-y-4">
                                <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Product Gallery (Max 4 Pictures)</label>
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                                    <div class="relative group">
                                        <input type="file" name="images" onchange="previewImage(this)" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                        <div class="w-full aspect-square bg-slate-50 border-2 border-dashed border-slate-100 rounded-2xl flex flex-col items-center justify-center group-hover:border-primary transition p-2 text-center">
                                            <i class="fas fa-camera text-slate-300 text-lg mb-1"></i>
                                            <span class="text-[8px] font-black uppercase text-slate-400">Main Image</span>
                                        </div>
                                    </div>
                                    <div class="relative group">
                                        <input type="file" name="images" onchange="previewImage(this)" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                        <div class="w-full aspect-square bg-slate-50 border-2 border-dashed border-slate-100 rounded-2xl flex flex-col items-center justify-center group-hover:border-primary transition p-2 text-center">
                                            <i class="fas fa-image text-slate-300 text-lg mb-1"></i>
                                            <span class="text-[8px] font-black uppercase text-slate-400">Image 2</span>
                                        </div>
                                    </div>
                                    <div class="relative group">
                                        <input type="file" name="images" onchange="previewImage(this)" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                        <div class="w-full aspect-square bg-slate-50 border-2 border-dashed border-slate-100 rounded-2xl flex flex-col items-center justify-center group-hover:border-primary transition p-2 text-center">
                                            <i class="fas fa-image text-slate-300 text-lg mb-1"></i>
                                            <span class="text-[8px] font-black uppercase text-slate-400">Image 3</span>
                                        </div>
                                    </div>
                                    <div class="relative group">
                                        <input type="file" name="images" onchange="previewImage(this)" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                        <div class="w-full aspect-square bg-slate-50 border-2 border-dashed border-slate-100 rounded-2xl flex flex-col items-center justify-center group-hover:border-primary transition p-2 text-center">
                                            <i class="fas fa-image text-slate-300 text-lg mb-1"></i>
                                            <span class="text-[8px] font-black uppercase text-slate-400">Image 4</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Product Video Link (YouTube/Vimeo/Direct)</label>
                                <input type="text" name="videoUrl" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary" placeholder="https://youtube.com/watch?v=...">
                            </div>

                            <div>
                                <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Product Description</label>
                                <textarea name="description" rows="3" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary" placeholder="Provide detailed product specifications..."></textarea>
                            </div>

                            <!-- Dynamic Specifications Section -->
                            <div class="space-y-4 pt-4 border-t border-slate-100">
                                <div class="flex justify-between items-center">
                                    <h3 class="text-xs font-black uppercase tracking-widest text-slate-400">Technical Specifications</h3>
                                    <button type="button" onclick="addSpecRow()" class="bg-slate-100 text-[10px] font-black uppercase px-3 py-1.5 rounded-lg hover:bg-primary hover:text-white transition">
                                        <i class="fas fa-plus mr-1"></i> Add Manual Detail
                                    </button>
                                </div>
                                
                                <div id="spec-presets" class="flex flex-wrap gap-2 mb-4">
                                    <p class="text-[9px] font-bold text-gray-400 w-full mb-1">SUGGESTIONS FOR <span id="current-category-name" class="text-primary font-black">GENERAL</span>:</p>
                                    <!-- Dynamic presets will appear here -->
                                </div>

                                <div id="spec-container" class="space-y-3">
                                    <!-- Manual rows will be added here -->
                                    <div class="flex items-center gap-3 spec-row">
                                        <input type="text" name="spec_keys[]" placeholder="e.g. Weight" class="w-1/3 bg-slate-50 border border-slate-100 rounded-xl px-4 py-2 text-xs focus:outline-none focus:border-primary font-bold">
                                        <input type="text" name="spec_values[]" placeholder="e.g. 50kg" class="flex-grow bg-slate-50 border border-slate-100 rounded-xl px-4 py-2 text-xs focus:outline-none focus:border-primary">
                                        <button type="button" onclick="this.parentElement.remove()" class="text-slate-300 hover:text-red-500 transition">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="w-full bg-primary text-white py-5 rounded-2xl text-[11px] uppercase tracking-widest font-black shadow-xl shadow-red-100 hover:scale-[1.02] transition active:scale-95">
                                Create New Auction <i class="fas fa-rocket ml-2"></i>
                            </button>
                        </form>
                    </section>

                    <!-- Quick View of Latest Orders -->
                    <section class="bg-white p-8 rounded-[40px] shadow-sm border border-slate-200 overflow-hidden">
                        <div class="flex justify-between items-center mb-6">
                            <h2 class="text-xl font-black text-slate-800">Recent <span class="text-slate-400">Activity</span></h2>
                            <button onclick="showSection('orders')" class="text-[10px] font-black uppercase text-primary border-b-2 border-primary pb-0.5">View All</button>
                        </div>
                        <div class="space-y-4">
                            <% orders.slice(0, 5).forEach(order => { %>
                                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-slate-400 shadow-sm">
                                            <i class="fas fa-shopping-cart text-xs"></i>
                                        </div>
                                        <div>
                                            <p class="text-xs font-bold text-slate-800"><%= order.username %></p>
                                            <p class="text-[9px] text-slate-400 uppercase font-black"><%= order.auction ? order.auction.title : 'Deleted Product' %></p>
                                        </div>
                                    </div>
                                    <p class="text-xs font-black text-green-600">₹<%= (order.totalAmount || 0).toLocaleString() %></p>
                                </div>
                            <% }) %>
                        </div>
                    </section>
                </div>
            </div>

            <!-- LOTS MANAGEMENT SECTION -->
            <div id="lots" class="admin-section p-8">
                <div class="flex justify-between items-center mb-10">
                    <h1 class="text-3xl font-black">Manage <span class="text-primary">Auctions</span></h1>
                    <button onclick="showSection('overview')" class="bg-white border border-slate-200 px-6 py-2 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-slate-50 transition">Add New Lot</button>
                </div>

                <div class="bg-white rounded-[40px] shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-slate-900 text-white">
                            <tr>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest">Product</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Base Price</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Live Price</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Stock</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Status</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% auctions.forEach(auction => { %>
                                <tr class="hover:bg-slate-50 transition">
                                    <td class="p-6">
                                        <div class="flex items-center gap-4">
                                            <div class="w-12 h-12 rounded-xl bg-slate-100 overflow-hidden border border-slate-200 shadow-sm flex-shrink-0">
                                                <img src="<%= auction.imageUrl || '/lot1.png' %>" class="w-full h-full object-cover">
                                            </div>
                                            <div>
                                                <p class="text-sm font-black text-slate-800"><%= auction.title %></p>
                                                <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest mt-0.5"><%= auction.category %></p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-6 text-center font-bold text-slate-500">₹<%= auction.initialPrice %></td>
                                    <td class="p-6 text-center font-black text-primary">₹<%= (auction.currentBid || auction.initialPrice || 0).toLocaleString() %></td>
                                    <td class="p-6 text-center">
                                        <span class="bg-slate-100 px-3 py-1 rounded-lg text-[10px] font-black text-slate-600 border border-slate-200">
                                            <%= auction.stockRemaining %> / <%= auction.lotSize %>
                                        </span>
                                    </td>
                                    <td class="p-6 text-center">
                                        <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest <%= auction.status === 'Closed' ? 'bg-red-100 text-red-600' : 'bg-green-100 text-green-600' %>">
                                            <%= auction.status || 'Active' %>
                                        </span>
                                    </td>
                                    <td class="p-6 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button onclick="openEditModal('<%= JSON.stringify(auction).replace(/'/g, "\\'") %>')" class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition">
                                                <i class="fas fa-edit text-xs"></i>
                                            </button>
                                            <form action="/admin/finalize-auction/<%= auction._id %>" method="POST" class="inline">
                                                <input type="hidden" name="winnerId" value="<%= users[0] ? users[0]._id : '' %>"> 
                                                <button title="Award & Close" class="w-8 h-8 rounded-lg bg-green-50 text-green-600 flex items-center justify-center hover:bg-green-600 hover:text-white transition">
                                                    <i class="fas fa-check-circle text-xs"></i>
                                                </button>
                                            </form>
                                            <form action="/admin/delete-product/<%= auction._id %>" method="POST" class="inline" onsubmit="return confirm('Pakka? This cannot be undone!')">
                                                <button class="w-8 h-8 rounded-lg bg-red-50 text-red-600 flex items-center justify-center hover:bg-red-600 hover:text-white transition">
                                                    <i class="fas fa-trash-alt text-xs"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- RETAILERS SECTION -->
            <div id="retailers" class="admin-section p-8">
                <div class="flex justify-between items-center mb-10">
                    <h1 class="text-3xl font-black font-heading">Retailer <span class="text-blue-600">Network</span></h1>
                    <div class="flex items-center gap-4">
                        <div class="text-[10px] font-black uppercase tracking-widest text-slate-400">Total Registered: <%= totalUsersCount %></div>
                        <button onclick="exportRetailersToCSV()" class="bg-blue-600 text-white px-5 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-700 transition shadow-lg shadow-blue-100 flex items-center gap-2">
                             <i class="fas fa-file-excel"></i> Export Excel
                        </button>
                    </div>
                </div>

                <div class="bg-white rounded-[40px] shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-slate-900 text-white">
                            <tr>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest">Retailer / Shop</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">City</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Shopping Coins</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Registered</th>
                                <th class="p-6 text-[10px] font-black uppercase tracking-widest text-right">Account</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% users.forEach((retailer, index) => { 
                                let globalRank = (currentPage - 1) * 20 + index;
                            %>
                                <tr class="hover:bg-slate-50 transition">
                                    <td class="p-6">
                                        <div class="flex items-center gap-4">
                                            <div class="relative">
                                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 border border-slate-200 font-black">
                                                    <%= (retailer.username || 'U').charAt(0).toUpperCase() %>
                                                </div>
                                                <% if (globalRank < 3) { 
                                                    let badgeColor = globalRank === 0 ? 'bg-yellow-400' : (globalRank === 1 ? 'bg-slate-300' : 'bg-amber-600');
                                                %>
                                                    <div class="absolute -top-1 -right-1 w-5 h-5 <%= badgeColor %> text-white text-[8px] flex items-center justify-center rounded-full border-2 border-white font-black shadow-sm" title="Top 3 Ranking">
                                                        <%= globalRank + 1 %>
                                                    </div>
                                                <% } %>
                                            </div>
                                            <div>
                                                <p class="text-[13px] font-black text-slate-800"><%= retailer.username %></p>
                                                <p class="text-[9px] text-red-600 font-black uppercase tracking-tighter"><%= retailer.shopName || 'NO SHOP' %></p>
                                                <p class="text-[8px] text-slate-400 font-bold mt-0.5"><%= retailer.email || 'retailer@bolibazar.com' %> | <%= retailer.phone || '9876543210' %></p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-6 text-center font-bold text-slate-600"><%= retailer.city || 'N/A' %></td>
                                    <td class="p-6 text-center">
                                        <span class="text-sm font-black text-yellow-600">
                                            <i class="fas fa-coins mr-1"></i><%= retailer.walletBalance ? Math.round(retailer.walletBalance).toLocaleString() : '0' %>
                                        </span>
                                    </td>
                                    <td class="p-6 text-center text-xs text-slate-400 font-bold">
                                        <%= new Date(retailer.createdAt).toLocaleDateString('en-IN') %>
                                    </td>
                                    <td class="p-6 text-right">
                                        <a href="/admin/retailer/<%= retailer._id %>" class="px-3 py-1 rounded-lg border border-slate-200 text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-slate-800 transition block text-center">View History</a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>

                    <!-- Pagination Controls -->
                    <% if (totalPages > 1) { %>
                    <div class="p-8 border-t border-slate-100 flex items-center justify-between">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                            Page <%= currentPage %> of <%= totalPages %>
                        </p>
                        <div class="flex items-center gap-2">
                            <% if (currentPage > 1) { %>
                                <a href="/admin?page=<%= currentPage - 1 %>&section=retailers" class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-slate-900 hover:text-white transition group">
                                    <i class="fas fa-chevron-left text-[10px]"></i>
                                </a>
                            <% } %>

                            <% let startPage = Math.max(1, currentPage - 2); 
                               let endPage = Math.min(totalPages, startPage + 4);
                               if (endPage - startPage < 4) startPage = Math.max(1, endPage - 4);
                            %>

                            <% for(let i = startPage; i <= endPage; i++) { %>
                                <a href="/admin?page=<%= i %>&section=retailers" class="w-10 h-10 rounded-xl flex items-center justify-center text-[10px] font-black transition <%= i === currentPage ? 'bg-slate-900 text-white' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
                                    <%= i %>
                                </a>
                            <% } %>

                            <% if (currentPage < totalPages) { %>
                                <a href="/admin?page=<%= currentPage + 1 %>&section=retailers" class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-slate-900 hover:text-white transition group">
                                    <i class="fas fa-chevron-right text-[10px]"></i>
                                </a>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- WINNING ORDERS SECTION -->
            <div id="orders" class="admin-section p-8">
                <% 
                    // Calculate Filtered Totals for the Summary Bar
                    let filteredOrderValue = 0;
                    let filteredReceived = 0;
                    let filteredBalance = 0;
                    
                    let count_delivered = 0;
                    let count_pending_delivery = 0;
                    let count_pending_cod_payment = 0;
                    
                    if (orders && orders.length > 0) {
                        orders.forEach(order => {
                            const sub = Math.round(order.totalAmount);
                            const f = (order.paymentMode === 'cod') ? Math.round(sub * 0.1) : 0;
                            const val = Math.round(sub + f);
                            
                            // SUM ALL PAYMENTS
                            const paid = Math.round((order.paymentHistory || []).reduce((sum, p) => sum + p.amount, 0));
                            const bal = Math.round(Math.max(0, val - paid));
                            
                            filteredOrderValue += val;
                            filteredReceived += paid;
                            filteredBalance += bal;

                            // Operation stats
                            if (order.status === 'Delivered') count_delivered++;
                            else count_pending_delivery++;

                            if (order.paymentMode === 'cod' && bal > 0.05) {
                                count_pending_cod_payment++;
                            }
                        });
                    }
                %>

                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-6">
                    <div>
                        <h1 class="text-3xl font-black font-heading tracking-tight">Winning <span class="text-green-600">Orders</span></h1>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">Showing result for selected date range</p>
                    </div>

                    <!-- Date Filter for Orders -->
                    <div class="flex flex-wrap items-center gap-4">
                        <form action="/admin" method="GET" class="flex items-center gap-3 bg-white p-2 rounded-2xl border border-slate-200 shadow-sm">
                            <input type="hidden" name="section" value="orders"> <!-- Hint to stay on this tab -->
                            <div class="flex items-center space-x-2 px-3 border-r border-slate-100">
                                <span class="text-[10px] font-black text-slate-400 uppercase">From:</span>
                                <input type="date" name="startDate" value="<%= startDate %>" class="text-xs font-bold focus:outline-none bg-transparent">
                            </div>
                            <div class="flex items-center space-x-2 px-3">
                                <span class="text-[10px] font-black text-slate-400 uppercase">To:</span>
                                <input type="date" name="endDate" value="<%= endDate %>" class="text-xs font-bold focus:outline-none bg-transparent">
                            </div>
                            <button type="submit" class="bg-green-600 text-white text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-xl hover:bg-green-700 transition">
                                Filter
                            </button>
                        </form>
                        <button onclick="exportOrdersToCSV()" class="bg-slate-900 text-white px-6 py-3 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-black transition shadow-lg shadow-slate-200">
                            <i class="fas fa-file-csv mr-2"></i> Export CSV
                        </button>
                    </div>
                </div>

                <!-- Summary Bar for Winning Orders -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                    <div class="bg-white p-6 rounded-[30px] border border-slate-200 shadow-sm">
                        <p class="text-[10px] font-black text-slate-400 uppercase mb-1 tracking-widest">Global Order Value</p>
                        <p class="text-2xl font-black text-slate-800">₹<%= filteredOrderValue.toLocaleString() %></p>
                        <div class="w-full h-1 bg-slate-100 rounded-full mt-4 overflow-hidden">
                            <div class="h-full bg-slate-400" style="width: 100%"></div>
                        </div>
                    </div>
                    <div class="bg-white p-6 rounded-[30px] border border-slate-200 shadow-sm ring-4 ring-green-500/5">
                        <p class="text-[10px] font-black text-green-500 uppercase mb-1 tracking-widest">Total Received (Advance/Full)</p>
                        <p class="text-2xl font-black text-green-600">₹<%= filteredReceived.toLocaleString() %></p>
                        <div class="w-full h-1 bg-green-100 rounded-full mt-4 overflow-hidden">
                            <div class="h-full bg-green-500" style="width: <%= (filteredOrderValue > 0) ? (filteredReceived / filteredOrderValue * 100) : 0 %>%"></div>
                        </div>
                    </div>
                    <div class="bg-white p-6 rounded-[30px] border border-slate-200 shadow-sm ring-4 ring-orange-500/5">
                        <p class="text-[10px] font-black text-orange-500 uppercase mb-1 tracking-widest">Total COD Pending</p>
                        <p class="text-2xl font-black text-orange-600">₹<%= filteredBalance.toLocaleString() %></p>
                        <div class="w-full h-1 bg-orange-100 rounded-full mt-4 overflow-hidden">
                            <div class="h-full bg-orange-500" style="width: <%= (filteredOrderValue > 0) ? (filteredBalance / filteredOrderValue * 100) : 0 %>%"></div>
                        </div>
                    </div>
                </div>

                <!-- NEW: Fulfillment Stats Row -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
                    <div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm hover:border-slate-300 transition">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-8 h-8 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center text-xs">
                                <i class="fas fa-shopping-basket"></i>
                            </div>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Total Received</span>
                        </div>
                        <p class="text-xl font-black text-slate-800"><%= orders.length %></p>
                    </div>
                    <div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm hover:border-green-300 transition">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-8 h-8 rounded-xl bg-green-50 text-green-500 flex items-center justify-center text-xs">
                                <i class="fas fa-box-check"></i>
                            </div>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Delivered Orders</span>
                        </div>
                        <p class="text-xl font-black text-slate-800"><%= count_delivered %></p>
                    </div>
                    <div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm hover:border-orange-300 transition">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-8 h-8 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center text-xs">
                                <i class="fas fa-truck-loading"></i>
                            </div>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Pending Delivery</span>
                        </div>
                        <p class="text-xl font-black text-slate-800"><%= count_pending_delivery %></p>
                    </div>
                    <div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm hover:border-red-300 transition">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-8 h-8 rounded-xl bg-red-50 text-red-500 flex items-center justify-center text-xs">
                                <i class="fas fa-hand-holding-dollar"></i>
                            </div>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">COD Pending</span>
                        </div>
                        <p class="text-xl font-black text-slate-800"><%= count_pending_cod_payment %></p>
                    </div>
                </div>

                <div class="bg-white rounded-[40px] shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-slate-900 text-white">
                                <tr>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest">Order Details</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Buyer</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Order Value</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center text-green-400">Paid Now</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center text-orange-400">Balance</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Mode</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Date</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-center">Status</th>
                                    <th class="p-6 text-[10px] font-black uppercase tracking-widest text-right px-10">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <% if (orders && orders.length > 0) { %>
                                    <% orders.forEach(order => { 
                                        const subtotal = Math.round(order.totalAmount);
                                        const fee = (order.paymentMode === 'cod') ? Math.round(subtotal * 0.1) : 0;
                                        const orderValue = Math.round(subtotal + fee);
                                        const paidNowTotal = Math.round((order.paymentHistory || []).reduce((sum, p) => sum + p.amount, 0));
                                        const balance = Math.round(orderValue - paidNowTotal);
                                        const isFullyPaid = paidNowTotal >= (orderValue - 1); 
                                    %>
                                        <tr class="hover:bg-slate-50 transition border-b border-slate-50">
                                            <td class="p-6">
                                                <p class="text-sm font-black text-slate-800 truncate max-w-[200px] transition cursor-default"><%= order.auction ? order.auction.title : 'Deleted Product' %></p>
                                                <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest mt-0.5">Order #<%= order._id.toString().slice(-8).toUpperCase() %></p>
                                            </td>
                                            <td class="p-6 text-center">
                                                <p class="text-xs font-bold text-slate-800"><%= order.username %></p>
                                                <p class="text-[9px] text-slate-400 uppercase font-black"><%= order.city %></p>
                                            </td>
                                            <td class="p-6 text-center font-bold text-slate-700 text-xs bg-slate-50/50 border-l border-slate-100">₹<%= orderValue.toLocaleString() %></td>
                                            <td class="p-6 text-center shadow-inner-sm">
                                                <p class="font-black text-green-600 text-xs">₹<%= paidNowTotal.toLocaleString() %></p>
                                                <% if(isFullyPaid) { %>
                                                    <span class="text-[8px] font-black uppercase text-green-500 tracking-tighter">Fully Paid</span>
                                                <% } else { %>
                                                    <span class="text-[8px] font-black uppercase text-orange-400 tracking-tighter">Advance Paid</span>
                                                <% } %>
                                            </td>
                                            <td class="p-6 text-center font-black text-orange-600 text-xs">₹<%= Math.max(0, balance).toLocaleString() %></td>
                                            <td class="p-6 text-center">
                                                <span class="px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-tighter border <%= order.paymentMode === 'full' ? 'bg-blue-50 text-blue-500 border-blue-100' : 'bg-orange-50 text-orange-500 border-orange-100' %>">
                                                    <%= order.paymentMode === 'full' ? 'FULL PREPAID' : 'COD' %>
                                                </span>
                                            </td>
                                            <td class="p-6 text-center text-[10px] font-bold text-slate-400">
                                                <%= new Date(order.createdAt).toLocaleString('en-IN', { day: '2-digit', month: 'short' }) %>
                                            </td>
                                            <td class="p-6 text-center">
                                                <span class="px-3 py-1 rounded-full <%= order.status === 'Delivered' ? 'bg-green-100 text-green-600 border-green-200' : 'bg-blue-100 text-blue-600 border-blue-200' %> text-[9px] font-black uppercase tracking-widest border">
                                                    <%= order.status %>
                                                </span>
                                            </td>
                                            <td class="p-6 text-right px-10">
                                                <div class="flex justify-end items-center gap-2">
                                                    <!-- Confirm Payment Action (Only for COD not fully paid) -->
                                                    <% if (order.paymentMode === 'cod' && !isFullyPaid) { %>
                                                        <button onclick="updateOrderStatus('<%= order._id %>', 'confirm-payment')" class="w-10 h-10 rounded-xl bg-green-600 text-white flex items-center justify-center hover:bg-green-700 transition shadow-lg shadow-green-100" title="Confirm Payment Received">
                                                            <i class="fas fa-check-double text-[12px]"></i>
                                                        </button>
                                                    <% } %>

                                                    <!-- Confirm Delivery & Invoice Action -->
                                                    <% if (order.status !== 'Delivered') { %>
                                                        <button onclick="updateOrderStatus('<%= order._id %>', 'deliver')" class="w-10 h-10 rounded-xl bg-slate-900 text-white flex items-center justify-center hover:bg-black transition shadow-lg shadow-slate-200" title="Mark as Delivered">
                                                            <i class="fas fa-truck text-[12px]"></i>
                                                        </button>
                                                    <% } else { %>
                                                        <a href="/admin/invoice/<%= order._id %>" target="_blank" class="w-10 h-10 rounded-xl bg-red-600 text-white flex items-center justify-center hover:bg-red-700 transition shadow-lg shadow-red-100" title="Download Invoice">
                                                            <i class="fas fa-file-invoice text-[12px]"></i>
                                                        </a>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="9" class="p-20 text-center">
                                            <i class="fas fa-shopping-basket text-slate-200 text-6xl mb-6"></i>
                                            <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">No orders found for this period</p>
                                        </td>
                                    </tr>
                                <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- MEDIA & BANNERS SECTION -->
            <div id="media" class="admin-section p-8">
                <div class="flex flex-col md:flex-row gap-10">
                    <!-- Upload Banner -->
                    <div class="flex-grow">
                        <section class="bg-white p-8 rounded-[40px] shadow-sm border border-slate-200">
                            <h2 class="text-xl font-black mb-6">Upload <span class="text-primary">Hero Banner</span></h2>
                            <form action="/admin/banners/upload" method="POST" enctype="multipart/form-data" class="space-y-4">
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Banner Title</label>
                                    <input type="text" name="title" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. Summer Sale">
                                </div>
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Banner Image (PNG/JPG)</label>
                                    <input type="file" name="bannerImage" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm">
                                </div>
                                <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-xl text-xs uppercase tracking-widest font-black shadow-lg shadow-slate-100 hover:bg-black transition">
                                    Upload & Launch Banner <i class="fas fa-upload ml-2"></i>
                                </button>
                            </form>
                        </section>
                    </div>
                    <!-- Live Banners -->
                    <div class="w-full md:w-1/3">
                        <section class="bg-white p-8 rounded-[40px] shadow-sm border border-slate-200">
                            <h2 class="text-xl font-black mb-6">Live <span class="text-slate-400">Banners</span></h2>
                            <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2">
                                <% banners.forEach(banner => { %>
                                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-2xl border border-slate-100">
                                        <div class="flex items-center gap-3">
                                            <img src="<%= banner.imageUrl %>" class="w-12 h-6 object-cover rounded shadow-sm">
                                            <p class="text-[10px] font-black text-slate-800 truncate w-24"><%= banner.title || 'Banner' %></p>
                                        </div>
                                        <form action="/admin/banners/delete/<%= banner._id %>" method="POST">
                                            <button class="w-7 h-7 rounded-lg bg-red-50 text-red-600 flex items-center justify-center hover:bg-red-600 hover:text-white transition">
                                                <i class="fas fa-times text-[10px]"></i>
                                            </button>
                                        </form>
                                    </div>
                                <% }) %>
                            </div>
                        </section>
                    </div>
                </div>
            </div>

            <!-- REWARDS SECTION -->
            <div id="rewards" class="admin-section p-8">
                <div class="flex items-center space-x-3 mb-10">
                    <i class="fas fa-trophy text-[#ffc107] text-2xl"></i>
                    <h1 class="text-3xl font-black font-heading">Leaderboard <span class="text-primary">Rewards</span></h1>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <% rewards.forEach(reward => { %>
                        <div class="bg-white p-8 rounded-[40px] border border-slate-200 flex flex-col items-center">
                            <div class="w-24 h-24 bg-slate-50 rounded-3xl border border-slate-100 overflow-hidden mb-6 shadow-sm">
                                <img src="<%= reward.imageUrl || '/lot1.png' %>" class="w-full h-full object-cover">
                            </div>
                            <div class="text-center mb-8">
                                <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest"><%= reward.rank === 1 ? '1st Place' : (reward.rank === 2 ? '2nd Place' : '3rd Place') %></span>
                                <h3 class="text-base font-black text-slate-800 mt-3"><%= reward.title %></h3>
                            </div>
                            
                            <form action="/admin/rewards/update" method="POST" enctype="multipart/form-data" class="w-full space-y-4 pt-6 border-t border-slate-100">
                                <input type="hidden" name="rank" value="<%= reward.rank %>">
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">Update Reward Title</label>
                                    <input type="text" name="title" value="<%= reward.title %>" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-xs focus:border-primary">
                                </div>
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-1">New Reward Image</label>
                                    <input type="file" name="rewardImage" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-2 text-[10px]">
                                </div>
                                <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-black transition shadow-sm">
                                    Save Reward #<%= reward.rank %>
                                </button>
                            </form>
                        </div>
                    <% }); %>
                </div>
            </div>

            <!-- HALL OF FAME ARCHIVE SECTION -->
            <div id="hallOfFame" class="admin-section p-8">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
                    <div>
                        <h1 class="text-3xl font-black">Hall of Fame <span class="text-primary">Archive</span></h1>
                        <p class="text-sm font-bold text-slate-400 mt-1 uppercase tracking-widest">History of Monthly Champions</p>
                    </div>
                    
                    <!-- Filter for Archive -->
                    <div class="flex items-center space-x-4">
                        <button onclick="forceResetLeaderboard()" class="px-6 py-3 bg-red-600 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-red-700 transition shadow-lg shadow-red-100/20">
                             Force Finalize Month <i class="fas fa-flag-checkered ml-2"></i>
                        </button>
                        <div class="flex items-center space-x-4 bg-white p-3 rounded-2xl border border-slate-200 shadow-sm">
                            <div class="flex items-center space-x-2 px-3 border-r border-slate-100">
                                <i class="fas fa-search text-slate-300"></i>
                                <input type="text" id="hofSearch" placeholder="Search Month/Winner/City..." class="text-xs font-bold focus:outline-none bg-transparent w-44" onkeyup="filterHOF()">
                            </div>
                        </div>
                    </div>
                </div>

                <% if (typeof hallOfFameSnapshots !== 'undefined' && hallOfFameSnapshots.length > 0) { %>
                    <div class="grid grid-cols-1 gap-10" id="hofContainer">
                        <% hallOfFameSnapshots.forEach(snapshot => { %>
                            <div class="hof-snapshot bg-white rounded-[2.5rem] border border-slate-200 shadow-sm overflow-hidden" data-month="<%= snapshot.month %>">
                                <!-- Snapshot Header -->
                                <div class="bg-slate-900 p-6 flex justify-between items-center">
                                    <h3 class="text-white text-xl font-black italic"><%= snapshot.month %></h3>
                                    <div class="bg-primary text-[10px] font-black uppercase px-4 py-1 rounded-full text-white tracking-widest">Archived Data</div>
                                </div>

                                <div class="p-8">
                                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                        <% snapshot.winners.forEach(winner => { 
                                            let rankColor = winner.rank === 1 ? 'text-yellow-500' : (winner.rank === 2 ? 'text-slate-400' : 'text-amber-700');
                                        %>
                                        <div class="bg-slate-50 border border-slate-100 p-6 rounded-3xl flex flex-col items-center text-center relative hover:shadow-lg transition">
                                            <div class="absolute top-4 right-4 text-xs font-black <%= rankColor %>">#<%= winner.rank %></div>
                                            
                                            <div class="w-16 h-16 rounded-2xl overflow-hidden mb-4 border border-slate-200 bg-white">
                                                <img src="<%= winner.profileImage || '/lot1.png' %>" class="w-full h-full object-cover">
                                            </div>
                                            
                                            <h4 class="font-black text-slate-900"><%= winner.shopName || winner.username %></h4>
                                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4"><%= winner.city %></p>
                                            
                                            <div class="w-full bg-white border border-slate-100 rounded-2xl py-3 px-4 flex justify-between items-center mt-auto">
                                                <div class="text-left">
                                                    <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1 text-slate-400">Score</p>
                                                    <p class="text-[10px] font-black text-slate-900"><%= (winner.coins || 0).toLocaleString() %></p>
                                                </div>
                                                <div class="text-right">
                                                    <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1 text-slate-400">Contact</p>
                                                    <p class="text-[10px] font-black text-primary"><%= winner.mobileNumber %></p>
                                                </div>
                                            </div>
                                        </div>
                                        <% }); %>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="bg-white rounded-[3rem] p-20 text-center border border-dashed border-slate-300">
                        <i class="fas fa-folder-open text-6xl text-slate-200 mb-6 block"></i>
                        <h3 class="text-xl font-bold text-slate-400">No Archives Found Yet</h3>
                        <p class="text-sm text-slate-300 mt-2">Archives will appear here after the first monthly reset.</p>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <!-- EDIT PRODUCT MODAL -->
    <div id="editModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-xl overflow-hidden animate-in fade-in zoom-in duration-300">
            <div class="p-8 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                <div>
                    <h3 class="text-xl font-black text-slate-800">Edit <span class="text-primary">Auction Lot</span></h3>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Modify pricing and details</p>
                </div>
                <button onclick="closeEditModal()" class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-red-500 hover:border-red-100 transition shadow-sm">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form id="editForm" method="POST" class="p-8 space-y-6">
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">Product Title</label>
                    <input type="text" name="title" id="editTitle" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-5 py-4 text-sm focus:outline-none focus:border-primary">
                </div>
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">Starting Price (₹)</label>
                        <input type="number" name="initialPrice" id="editPrice" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-5 py-4 text-sm focus:outline-none focus:border-primary">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">Total Lot Size</label>
                        <input type="number" name="lotSize" id="editLotSize" required class="w-full bg-slate-50 border border-slate-100 rounded-xl px-5 py-4 text-sm focus:outline-none focus:border-primary">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">Category</label>
                        <select name="category" id="editCategory" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-5 py-4 text-sm focus:outline-none focus:border-primary">
                            <option>Grocery</option>
                            <option>Beverages</option>
                            <option>Personal Care</option>
                            <option>Snacks</option>
                        </select>
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">Image URL</label>
                        <input type="text" name="imageUrl" id="editImageUrl" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-5 py-4 text-sm focus:outline-none focus:border-primary">
                    </div>
                </div>
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase block mb-2">Description</label>
                    <textarea name="description" id="editDesc" rows="3" class="w-full bg-slate-50 border border-slate-100 rounded-xl px-5 py-4 text-sm focus:outline-none focus:border-primary"></textarea>
                </div>
                <button type="submit" class="w-full bg-primary text-white py-5 rounded-2xl text-[11px] uppercase tracking-widest font-black shadow-xl shadow-red-100 hover:scale-[1.02] transition active:scale-95">
                    Update Auction Details <i class="fas fa-save ml-2"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- SCRIPTS -->
    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Tab Navigation
        function showSection(sectionId) {
            document.querySelectorAll('.admin-section').forEach(section => {
                section.classList.remove('active');
            });
            document.querySelectorAll('.sidebar-link').forEach(link => {
                link.classList.remove('active', 'bg-slate-900', 'text-white');
                link.classList.add('text-slate-400');
            });

            const targetSection = document.getElementById(sectionId);
            if (targetSection) {
                targetSection.classList.add('active');
            }
            
            // Find active button
            const activeBtn = Array.from(document.querySelectorAll('.sidebar-link')).find(btn => 
                btn.getAttribute('onclick').includes(sectionId)
            );
            if (activeBtn) {
                activeBtn.classList.add('active');
                activeBtn.classList.remove('text-slate-400');
            }

            // Save active tab
            localStorage.setItem('adminActiveTab', sectionId);
        }

        // Initialize active section on load
        window.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const sectionParam = urlParams.get('section');
            const savedSection = localStorage.getItem('adminActiveTab');
            
            if (sectionParam) {
                showSection(sectionParam);
            } else if (savedSection) {
                showSection(savedSection);
            } else {
                showSection('overview');
            }
        });

        async function forceResetLeaderboard() {
            if (!confirm('WARNING: This will finalize the current month, archive top 3 winners, and RESET ALL RETAILER BALANCES to 0. Proceed?')) return;
            try {
                const res = await fetch('/api/admin/force-reset-leaderboard', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert('Error: ' + data.error);
                }
            } catch (err) {
                alert('Server Error');
            }
        }

        function filterHOF() {
            const query = document.getElementById('hofSearch').value.toLowerCase();
            const snapshots = document.querySelectorAll('.hof-snapshot');
            snapshots.forEach(s => {
                const month = s.getAttribute('data-month').toLowerCase();
                const textContent = s.innerText.toLowerCase();
                
                if (month.includes(query) || textContent.includes(query)) {
                    s.style.display = 'block';
                } else {
                    s.style.display = 'none';
                }
            });
        }

        // Persistent Tab Logic & Chart Initialization
        document.addEventListener('DOMContentLoaded', () => {
            const savedTab = localStorage.getItem('adminActiveTab');
            if (savedTab) showSection(savedTab);

            // Initialize Sales Performance Chart
            const chartCanvas = document.getElementById('salesChart');
            if (chartCanvas) {
                const ctx = chartCanvas.getContext('2d');
                const gradient = ctx.createLinearGradient(0, 0, 0, 300);
                gradient.addColorStop(0, 'rgba(217, 4, 41, 0.15)');
                gradient.addColorStop(1, 'rgba(217, 4, 41, 0)');

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: <%- JSON.stringify(weekLabels) %>,
                        datasets: [{
                            label: 'Daily Collection',
                            data: <%= JSON.stringify(weekData) %>,
                            borderColor: '#d90429',
                            borderWidth: 3,
                            fill: true,
                            backgroundColor: gradient,
                            tension: 0.4,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#d90429',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#0f172a',
                                padding: 12,
                                displayColors: false,
                                callbacks: {
                                    label: (context) => `₹ ${context.parsed.y.toLocaleString()}`
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f1f5f9' },
                                ticks: { 
                                    font: { weight: '600' },
                                    callback: (v) => '₹' + v.toLocaleString()
                                }
                            },
                            x: {
                                grid: { display: false },
                                ticks: { font: { weight: '600' } }
                            }
                        }
                    }
                });
            }
        });

        // Auction Management
        function openEditModal(auctionData) {
            const auction = JSON.parse(auctionData);
            document.getElementById('editForm').action = `/admin/update-product/${auction._id}`;
            document.getElementById('editTitle').value = auction.title;
            document.getElementById('editPrice').value = auction.initialPrice;
            document.getElementById('editLotSize').value = auction.lotSize;
            document.getElementById('editCategory').value = auction.category;
            document.getElementById('editImageUrl').value = auction.imageUrl || '';
            document.getElementById('editDesc').value = auction.description || '';
            document.getElementById('editModal').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('editModal').classList.add('hidden');
        }

        async function toggleStatus(id) {
            try {
                const response = await fetch(`/api/auctions/${id}/toggle-status`, { method: 'POST' });
                if (response.ok) window.location.reload();
            } catch (err) { alert('Update failed'); }
        }

        // Order Actions
        async function deliverOrder(id) {
            if (!confirm('Mark as DELIVERED? This will generate the invoice.')) return;
            try {
                const res = await fetch(`/api/admin/orders/${id}/deliver`, { method: 'POST' });
                const data = await res.json();
                if (data.success) window.location.reload();
                else alert('Error: ' + data.error);
            } catch (err) { alert('Server Error'); }
        }

        async function confirmCodPayment(id) {
            if (!confirm('Receive final COD payment?')) return;
            try {
                const res = await fetch(`/api/admin/orders/${id}/confirm-payment`, { method: 'POST' });
                const data = await res.json();
                if (data.success) window.location.reload();
                else alert('Error: ' + data.error);
            } catch (err) { alert('Server Error'); }
        }

        function updateOrderStatus(orderId, action) {
            if (!confirm(`Are you sure you want to ${action}?`)) return;
            fetch(`/api/admin/orders/${orderId}/${action}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) window.location.reload();
                    else alert('Error: ' + data.error);
                });
        }

        // CSV Export
        function exportOrdersToCSV() {
            const orders = <%- JSON.stringify(orders) %>;
            if (!orders || orders.length === 0) return alert("No data to export.");

            let csv = "Order ID,Product,Buyer,City,Payment Mode,Order Value,Paid Now,Balance,Date,Status\n";
            orders.forEach(o => {
                const sub = o.totalAmount;
                const fee = (o.paymentMode === 'cod') ? (sub * 0.1) : 0;
                const date = new Date(o.createdAt).toLocaleString('en-IN');
                const row = [
                    o._id.toString().slice(-8).toUpperCase(),
                    `"${(o.auction?.title || 'N/A').replace(/"/g, '""')}"`,
                    `"${o.username.replace(/"/g, '""')}"`,
                    `"${(o.city || 'N/A').replace(/"/g, '""')}"`,
                    o.paymentMode.toUpperCase(),
                    sub + fee,
                    (o.paymentHistory || []).reduce((s, p) => s + p.amount, 0),
                    (sub + fee) - (o.paymentHistory || []).reduce((s, p) => s + p.amount, 0),
                    `"${date}"`,
                    o.status
                ].join(",");
                csv += row + "\n";
            });

            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = `Orders_Report_${new Date().toISOString().slice(0,10)}.csv`;
            link.click();
        }

        function exportRetailersToCSV() {
            const users = <%- JSON.stringify(users) %>;
            if (!users || users.length === 0) return alert("No retailer data to export.");

            let csv = "Retailer Name,Shop Name,Email,Mobile No,City,Shopping Coins,Registration Date\n";
            users.forEach(u => {
                const date = new Date(u.createdAt).toLocaleDateString('en-IN');
                const row = [
                    `"${(u.username || '').replace(/"/g, '""')}"`,
                    `"${(u.shopName || 'N/A').replace(/"/g, '""')}"`,
                    `"${(u.email || '').replace(/"/g, '""')}"`,
                    `="${u.phone || 'N/A'}"`, // Use ="text" format for Excel to preserve leading zeros
                    `"${(u.city || 'N/A').replace(/"/g, '""')}"`,
                    u.walletBalance || 0,
                    `"${date}"`
                ].join(",");
                csv += row + "\n";
            });

            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            link.download = `Retailers_Full_Network_${new Date().toISOString().slice(0,10)}.csv`;
            link.click();
        }
    </script>
</body>
</html>
