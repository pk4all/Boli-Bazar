<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Auctions | BoliBazar | Factory to Retailer</title>
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        'primary-dark': '#ef233c',
                        secondary: '#001f3f',
                        'bg-light': '#f8f9fa',
                    }
                }
            }
        }
    </script>
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #fff; }
        .font-heading { font-family: 'Outfit', sans-serif; }
    </style>
</head>
<body class="text-secondary pb-20">

    <!-- Header Navigation (Minimalist) -->
    <header class="bg-white py-4 px-6 border-b border-gray-100 sticky top-0 z-[100] backdrop-blur-md bg-white/90">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="flex items-center space-x-2">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white">
                    <i class="fas fa-gavel text-sm"></i>
                </div>
                <span class="text-xl font-black tracking-tighter uppercase font-heading">
                    Boli<span class="text-primary">Bazar</span>
                </span>
            </a>
            <div class="flex items-center space-x-6">
                 <% if (user) { %>
                    <a href="/dashboard" class="text-xs font-black uppercase tracking-widest text-gray-500 hover:text-primary transition">Dashboard</a>
                    <a href="/logout" class="text-xs font-black uppercase tracking-widest text-primary">Logout</a>
                 <% } else { %>
                    <a href="/login" class="text-xs font-black uppercase tracking-widest text-gray-500">Login</a>
                    <a href="/register" class="bg-primary text-white px-5 py-2 rounded-full text-xs font-black uppercase tracking-widest">Join</a>
                 <% } %>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 pt-10">
        
        <!-- Search & Core Filters -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-4 mb-8">
            <div class="relative w-full md:max-w-xl">
                <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-gray-300"></i>
                <input type="text" id="productSearch" placeholder="Product name search karein..." class="w-full pl-14 pr-6 py-4 rounded-3xl bg-white border border-gray-100 text-sm focus:outline-none focus:border-primary/30 search-input-shadow">
            </div>
            
            <div class="flex items-center space-x-3 w-full md:w-auto overflow-x-auto pb-2 md:pb-0">
                <button class="filter-tab filter-tab-active status-filter" data-status="all">
                     <span>Sab Lots</span>
                     <span class="bg-white/20 text-white w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-black"><%= auctions.length %></span>
                </button>
                <button class="filter-tab filter-tab-inactive status-filter" data-status="live">
                     <span>Live Now</span>
                     <span class="bg-gray-100 text-gray-400 w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-black">8</span>
                </button>
                <button class="filter-tab filter-tab-inactive status-filter" data-status="closing">
                     <span>Closing Soon</span>
                     <span class="bg-gray-100 text-gray-400 w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-black">1</span>
                </button>
            </div>
        </div>

        <div class="flex items-center space-x-3 mb-10 overflow-x-auto pb-4 no-scrollbar">
            <i class="fas fa-tags text-gray-300 text-xs transform -rotate-45"></i>
            <button class="pill-chip pill-chip-active category-filter" data-category="all">All</button>
            <button class="pill-chip pill-chip-inactive category-filter" data-category="Grains">Grains</button>
            <button class="pill-chip pill-chip-inactive category-filter" data-category="Oils">Oils</button>
            <button class="pill-chip pill-chip-inactive category-filter" data-category="Pulses">Pulses</button>
            <button class="pill-chip pill-chip-inactive category-filter" data-category="Sugar">Sugar</button>
            <button class="pill-chip pill-chip-inactive category-filter" data-category="Condiments">Condiments</button>
        </div>

        <!-- Section Title -->
        <div class="flex justify-between items-center mb-10">
            <h2 class="text-2xl font-black font-heading flex items-center">
                <span class="w-2 h-2 bg-primary rounded-full mr-3"></span>
                Live Lots <span class="text-gray-300 text-sm font-bold ml-2">(<%= auctions.length %> available)</span>
            </h2>
            <div class="text-gray-400 text-[10px] font-black uppercase tracking-widest flex items-center">
                <i class="fas fa-chart-line mr-2"></i> Real-time prices
            </div>
        </div>

        <!-- Auction Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <% auctions.forEach(auction => { %>
                <div class="auction-card bg-white rounded-[2rem] border border-gray-100 overflow-hidden group hover:shadow-2xl hover:shadow-gray-200/50 transition duration-500" 
                     data-category="<%= auction.category %>" 
                     data-title="<%= auction.title.toLowerCase() %>" 
                     data-closing="<%= auction.closingSoon %>">
                    
                    <!-- Image Area -->
                    <div class="relative h-56 overflow-hidden">
                        <img src="<%= auction.imageUrl %>" class="w-full h-full object-cover transition duration-700 group-hover:scale-110">
                        
                        <!-- Badges -->
                        <% if (auction.isFeatured) { %>
                            <div class="badge-float badge-featured left-3">
                                <i class="fas fa-star"></i> Featured
                            </div>
                        <% } %>
                        
                        <% if (auction.closingSoon) { %>
                            <div class="badge-float badge-closing <%= auction.isFeatured ? 'left-24' : 'left-3' %>">
                                <i class="fas fa-bolt"></i> Closing Soon!
                            </div>
                        <% } %>

                        <div class="badge-float badge-timer right-3">
                            <i class="far fa-clock"></i> 03:39
                        </div>

                        <!-- Category Tag on Image -->
                        <div class="absolute bottom-3 left-3 bg-white text-gray-500 px-3 py-1 rounded-full text-[9px] font-black uppercase shadow-sm">
                            <%= auction.category %>
                        </div>
                    </div>

                    <!-- Content Area -->
                    <div class="p-6">
                        <h3 class="text-xl font-black leading-tight mb-1 text-secondary"><%= auction.title %></h3>
                        <p class="text-[12px] font-medium text-gray-400 mb-5 italic">
                            <%= auction.description %>
                        </p>

                        <!-- MOQ Indicator -->
                        <div class="moq-banner py-2.5 px-4">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-box-open text-orange-500 text-xs"></i>
                                <span class="text-[11px] font-black">Min. Order: <%= auction.moq %> <%= auction.unitType %></span>
                            </div>
                            <span class="text-[10px] opacity-40 font-black">MOQ</span>
                        </div>

                        <!-- Price Section -->
                        <div class="mb-5 relative flex items-start justify-between">
                            <div class="flex-grow">
                                <p class="text-[10px] font-bold text-gray-300 uppercase mb-1.5 tracking-wider">Current Price</p>
                                <h4 class="text-[32px] font-black leading-none tracking-tight text-secondary">₹<%= auction.currentBid.toLocaleString() %></h4>
                                <p class="text-[10px] text-gray-400 font-bold mt-2 opacity-60">Started at ₹<%= auction.initialPrice.toLocaleString() %></p>
                            </div>
                            <div class="text-right pt-4 flex flex-col items-end">
                                <div class="w-16 h-[2px] bg-[#d90429] mb-4"></div>
                                <p class="text-[11px] font-black text-primary uppercase flex items-center tracking-tight">
                                    <i class="fas fa-arrow-up transform rotate-45 mr-1 text-[8px]"></i> +<%= auction.hikePercentage %>% hike
                                </p>
                            </div>
                        </div>

                        <!-- Three Column Stats -->
                        <div class="grid grid-cols-3 gap-2.5 mb-6">
                             <div class="bg-[#f8f9fa] rounded-xl py-3 text-center border border-gray-100/50">
                                 <p class="text-[9px] font-bold text-gray-400 uppercase mb-1">Buyers</p>
                                 <p class="text-lg font-black text-secondary"><%= auction.totalBuyers %></p>
                             </div>
                             <div class="bg-[#f8f9fa] rounded-xl py-3 text-center border border-gray-100/50">
                                 <p class="text-[9px] font-bold text-gray-400 uppercase mb-1">Remaining</p>
                                 <p class="text-lg font-black text-secondary"><%= auction.stockRemaining %></p>
                             </div>
                             <div class="bg-[#f8f9fa] rounded-xl py-3 text-center border border-gray-100/50">
                                 <p class="text-[9px] font-bold text-gray-400 uppercase mb-1">Sold</p>
                                 <p class="text-lg font-black text-primary"><%= auction.stockSoldPercent %>%</p>
                             </div>
                        </div>

                        <!-- Stock Bar -->
                        <div class="mb-8">
                            <div class="flex justify-between items-center mb-2 px-0.5">
                                <span class="text-[10px] font-bold text-gray-400 uppercase">Stock sold</span>
                                <span class="text-[11px] font-black text-primary"><%= auction.stockSoldPercent %>%</span>
                            </div>
                            <div class="h-[10px] w-full bg-gray-100 rounded-full overflow-hidden">
                                <div class="h-full bg-primary rounded-full" style="width: <%= auction.stockSoldPercent %>%"></div>
                            </div>
                        </div>

                        <!-- Bid Button -->
                        <a href="/auctions/<%= auction._id %>" class="w-full bg-[#d90429] hover:bg-red-700 text-white h-14 rounded-[1.5rem] text-sm font-black uppercase flex items-center justify-center gap-4 transition-all shadow-xl shadow-red-500/20 active:scale-95">
                            <i class="fas fa-bolt text-sm"></i>
                            <span>Bid Now</span>
                            <i class="fas fa-chevron-right text-[10px] opacity-60"></i>
                        </a>
                    </div>
                </div>
            <% }); %>
        </div>

        <!-- Upcoming Lots Section -->
        <% if (locals.upcomingAuctions && locals.upcomingAuctions.length > 0) { %>
            <div class="upcoming-section">
                <!-- Section Header -->
                <div class="flex items-start gap-4 mb-10">
                    <div class="w-10 h-10 bg-indigo-50 border border-indigo-100 rounded-xl flex items-center justify-center text-indigo-500 shadow-sm">
                        <i class="far fa-clock text-lg"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-black font-heading leading-tight">Upcoming Lots — Kal kya aayega</h2>
                        <p class="text-[11px] font-bold text-gray-400">In lots ka countdown chal raha hai</p>
                    </div>
                </div>

                <!-- Upcoming Cards Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% (locals.upcomingAuctions || []).forEach(auction => { %>
                        <div class="upcoming-lot-card group">
                            <!-- Image Area with Grayscale & Stats Overlay -->
                            <div class="upcoming-img-container">
                                <img src="<%= auction.imageUrl %>" class="upcoming-img">
                                <div class="upcoming-overlay">
                                    <span>Starts in</span>
                                    <span>12h 52m mein</span>
                                </div>
                            </div>

                            <!-- Content Area -->
                            <div class="p-5">
                                <h3 class="text-[15px] font-black leading-tight mb-4 text-secondary group-hover:text-primary transition"><%= auction.title %></h3>
                                
                                <div class="flex items-end justify-between mb-5">
                                    <div>
                                        <p class="text-[9px] font-bold text-gray-300 uppercase tracking-wider mb-1">Starting Price</p>
                                        <p class="text-lg font-black text-primary leading-none">₹<%= auction.initialPrice.toLocaleString() %></p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-[9px] font-bold text-gray-300 uppercase tracking-wider mb-1">Qty</p>
                                        <p class="text-lg font-black text-secondary leading-none"><%= auction.lotSize %></p>
                                    </div>
                                </div>

                                <!-- Notify Button -->
                                <button class="btn-notify">
                                    <i class="far fa-bell"></i>
                                    Notify Me
                                </button>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        <% } %>

        <!-- Recently Closed Section -->
        <% if (locals.closedAuctions && locals.closedAuctions.length > 0) { %>
            <div class="closed-section">
                <!-- Section Header -->
                <div class="flex items-start gap-4 mb-10">
                    <div class="w-10 h-10 bg-gray-50 border border-gray-100 rounded-xl flex items-center justify-center text-gray-500 shadow-sm">
                        <i class="fas fa-gavel text-lg"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-black font-heading leading-tight">Recently Closed Lots</h2>
                        <p class="text-[11px] font-bold text-gray-400">Winner lots ki list yahan hai</p>
                    </div>
                </div>

                <!-- Closed Cards Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% (locals.closedAuctions || []).forEach(auction => { %>
                        <div class="closed-lot-card group">
                            <!-- Image Area with Closed Badge -->
                            <div class="closed-img-container">
                                <img src="<%= auction.imageUrl %>" class="closed-img">
                                <div class="badge-closed">
                                    <i class="fas fa-check-circle mr-1"></i> Closed
                                </div>
                            </div>

                            <!-- Content Area -->
                            <div class="p-5 bg-white">
                                <h3 class="text-[15px] font-black leading-tight mb-4 text-secondary opacity-60"><%= auction.title %></h3>
                                
                                <div class="flex items-end justify-between mb-4">
                                    <div>
                                        <p class="text-[9px] font-bold text-gray-300 uppercase tracking-wider mb-1">Sold Price</p>
                                        <p class="text-lg font-black text-secondary leading-none">₹<%= auction.currentBid.toLocaleString() %></p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-[9px] font-bold text-gray-300 uppercase tracking-wider mb-1">Final Gain</p>
                                        <p class="text-[14px] font-black text-primary leading-none">+<%= auction.hikePercentage %>%</p>
                                    </div>
                                </div>

                                <div class="pt-4 border-t border-gray-50 flex justify-between items-center">
                                    <span class="text-[10px] font-bold text-gray-400 uppercase">Auction Ended</span>
                                    <span class="text-[10px] font-bold text-secondary"><%= auction.totalBuyers %> Buyers Participated</span>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        <% } %>
    </main>

    <!-- Pixel Perfect Bid Notification (Matches Screenshot) -->
    <div class="fixed bottom-8 right-8 z-[200]" id="bid-toast">
        <div class="bg-[#eff6ff] border border-blue-200 rounded-3xl p-6 shadow-2xl flex items-center gap-5 max-w-[450px] animate-slide-up">
            <div class="w-14 h-14 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 shadow-sm">
                <i class="fas fa-info-circle text-xl"></i>
            </div>
            <div class="flex-grow">
                <p class="text-[14px] font-medium text-blue-800 leading-tight">
                    🔥 <span class="font-bold">Rajiv Nair (Kochi)</span> ne bid kiya — price <span class="font-bold text-blue-900">₹1,310.29</span> ho gaya!
                </p>
            </div>
        </div>
    </div>

    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        @keyframes slide-up {
            from { transform: translateY(100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-up { animation: slide-up 0.5s cubic-bezier(0.2, 0.8, 0.2, 1); }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('productSearch');
            const categoryButtons = document.querySelectorAll('.category-filter');
            const statusButtons = document.querySelectorAll('.status-filter');
            const auctionCards = document.querySelectorAll('.auction-card');
            const availableLotsCount = document.querySelector('.text-gray-300.text-sm.font-bold.ml-2');

            let activeCategory = 'all';
            let activeStatus = 'all';
            let searchQuery = '';

            function filterAuctions() {
                let visibleCount = 0;
                
                auctionCards.forEach(card => {
                    const category = card.getAttribute('data-category');
                    const title = card.getAttribute('data-title');
                    const isClosing = card.getAttribute('data-closing') === 'true';
                    
                    const matchesCategory = activeCategory === 'all' || category === activeCategory;
                    const matchesSearch = title.includes(searchQuery.toLowerCase());
                    const matchesStatus = activeStatus === 'all' || 
                                        (activeStatus === 'closing' && isClosing) ||
                                        (activeStatus === 'live'); // Assuming all in DB are live for now

                    if (matchesCategory && matchesSearch && matchesStatus) {
                        card.style.display = 'block';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                });

                availableLotsCount.textContent = `(${visibleCount} available)`;
            }

            // Category Filter
            categoryButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    categoryButtons.forEach(b => {
                        b.classList.remove('pill-chip-active');
                        b.classList.add('pill-chip-inactive');
                    });
                    btn.classList.add('pill-chip-active');
                    btn.classList.remove('pill-chip-inactive');
                    activeCategory = btn.getAttribute('data-category');
                    filterAuctions();
                });
            });

            // Status Filter
            statusButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    statusButtons.forEach(b => {
                        b.classList.remove('filter-tab-active');
                        b.classList.add('filter-tab-inactive');
                        const badge = b.querySelector('span:last-child');
                        if (badge) {
                            badge.classList.remove('bg-white/20', 'text-white');
                            badge.classList.add('bg-gray-100', 'text-gray-400');
                        }
                    });
                    btn.classList.add('filter-tab-active');
                    btn.classList.remove('filter-tab-inactive');
                    const badge = btn.querySelector('span:last-child');
                    if (badge) {
                        badge.classList.add('bg-white/20', 'text-white');
                        badge.classList.remove('bg-gray-100', 'text-gray-400');
                    }
                    activeStatus = btn.getAttribute('data-status');
                    filterAuctions();
                });
            });

            // Search Filter
            searchInput.addEventListener('input', (e) => {
                searchQuery = e.target.value;
                filterAuctions();
            });
        });
    </script>
    <!-- Sticky Trust Scroller (News Ticker Style) -->
    <div class="trust-scroller-container">
        <div class="trust-scroller">
            <!-- First Set -->
            <div class="trust-item">
                <i class="fas fa-money-bill-wave"></i>
                <div class="trust-info">
                    <h5>10% Advance Mandatory</h5>
                    <p>Token se booking confirm karein</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-truck-fast"></i>
                <div class="trust-info">
                    <h5>100% Full Payment = FREE Delivery</h5>
                    <p>Poora pay karo, delivery free pao</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-box"></i>
                <div class="trust-info">
                    <h5>COD = 10% Extra Delivery</h5>
                    <p>90% balance + 10% delivery charge</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-shield-alt"></i>
                <div class="trust-info">
                    <h5>Quality Checked by BoliBazar</h5>
                    <p>100% genuine products factory direct</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-file-invoice-dollar"></i>
                <div class="trust-info">
                    <h5>GST Invoice Available</h5>
                    <p>Business tax credit claim karein</p>
                </div>
            </div>
            <!-- Duplicate for infinite loop -->
            <div class="trust-item">
                <i class="fas fa-money-bill-wave"></i>
                <div class="trust-info">
                    <h5>10% Advance Mandatory</h5>
                    <p>Token se booking confirm karein</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-truck-fast"></i>
                <div class="trust-info">
                    <h5>100% Full Payment = FREE Delivery</h5>
                    <p>Poora pay karo, delivery free pao</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-box"></i>
                <div class="trust-info">
                    <h5>COD = 10% Extra Delivery</h5>
                    <p>90% balance + 10% delivery charge</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-shield-alt"></i>
                <div class="trust-info">
                    <h5>Quality Checked by BoliBazar</h5>
                    <p>100% genuine products factory direct</p>
                </div>
            </div>
            <div class="trust-item">
                <i class="fas fa-file-invoice-dollar"></i>
                <div class="trust-info">
                    <h5>GST Invoice Available</h5>
                    <p>Business tax credit claim karein</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
