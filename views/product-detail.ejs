    <!-- Pixel Perfect Bid Notification (Matches Screenshot) -->
    <div class="fixed bottom-8 right-8 z-[200]" id="bid-toast">
        <div class="bg-[#eff6ff] border border-blue-200 rounded-3xl p-6 shadow-2xl flex items-center gap-5 max-w-[450px] animate-slide-up">
            <div class="w-14 h-14 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 shadow-sm">
                <i class="fas fa-info-circle text-xl"></i>
            </div>
            <div class="flex-grow">
                <p class="text-[14px] font-medium text-blue-800 leading-tight">
                    🔥 <span class="font-bold">Rajiv Nair (Kochi)</span> ne bid kiya — price <span class="font-bold text-blue-900">₹1,310.29</span> ho gaya!
                </p>
            </div>
        </div>
    </div>

    <script>
        const currentPrice = <%= auction.currentBid %>;

        function switchTab(tabName) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
            document.getElementById(tabName + '-tab').classList.remove('hidden');
        }

        function adjustQty(delta) {
            const input = document.getElementById('bidQty');
            let val = (parseInt(input.value) || 0) + delta;
            if (val < <%= auction.moq || 1 %>) val = <%= auction.moq || 1 %>;
            input.value = val;
            calculateTotal();
        }

        function setQty(val) {
            document.getElementById('bidQty').value = val;
            calculateTotal();
        }

        let paymentMode = 'full';

        function setPaymentMode(mode) {
            paymentMode = mode;
            document.querySelectorAll('.payment-card').forEach(card => card.classList.remove('active', 'border-primary', 'bg-red-50/20'));
            document.getElementById('pay-' + mode).classList.add('active', 'border-primary', 'bg-red-50/20');
            
            if (mode === 'cod') {
                document.getElementById('cod-row-balance').classList.remove('hidden');
                document.getElementById('cod-row-fee').classList.remove('hidden');
            } else {
                document.getElementById('cod-row-balance').classList.add('hidden');
                document.getElementById('cod-row-fee').classList.add('hidden');
            }
            calculateTotal();
        }

        function calculateTotal() {
            const qty = parseInt(document.getElementById('bidQty').value) || 0;
            const subtotal = qty * currentPrice;
            const advance = subtotal * 0.1;
            const balance = subtotal * 0.9;
            const fee = paymentMode === 'cod' ? subtotal * 0.1 : 0;
            const total = paymentMode === 'cod' ? (subtotal + fee) : subtotal;

            // From Image: 
            // Current Price x 5 = 1,61,66,197
            // Advance = 16,16,619
            // Balance = 1,45,49,577
            // Fee = 16,16,619
            // Total = 1,61,66,197 (Wait, subtotal is total? Then fee is included in subtotal or added? Actually total = subtotal usually)

            document.getElementById('display-qty').textContent = qty;
            document.getElementById('display-subtotal').textContent = `₹${subtotal.toLocaleString()}`;
            document.getElementById('display-advance').textContent = `₹${advance.toLocaleString()}`;
            document.getElementById('display-balance').textContent = `₹${balance.toLocaleString()}`;
            document.getElementById('display-fee').textContent = `+₹${fee.toLocaleString()}`;
            const totalDisplay = document.getElementById('billing-total-payable');
            if (totalDisplay) {
                totalDisplay.textContent = `₹${total.toLocaleString()}`;
            }

            // Update chips
            document.querySelectorAll('.qty-chip').forEach(chip => {
                if (parseInt(chip.dataset.qty) === qty) {
                    chip.classList.add('bg-primary', 'text-white', 'shadow-lg');
                    chip.classList.remove('bg-gray-50', 'text-gray-400');
                } else {
                    chip.classList.remove('bg-primary', 'text-white', 'shadow-lg');
                    chip.classList.add('bg-gray-50', 'text-gray-400');
                }
            });
        }

        document.addEventListener('DOMContentLoaded', calculateTotal);

        // Auto Close Toast
        setTimeout(() => {
            const toast = document.getElementById('bid-toast');
            if (toast) {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(20px)';
                toast.style.transition = 'all 0.5s';
            }
        }, 8000);
    </script>

    <style>
        .no-scrollbar::-webkit-scrollbar { display: none; }
        @keyframes slide-up {
            from { transform: translateY(100%); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-up { animation: slide-up 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); }
    </style>

</body>
</html>
