                                        <i class="fas fa-box text-xs text-gray-400 group-hover:text-primary transition"></i>
                                        <span class="text-[10px] font-black uppercase text-secondary">COD</span>
                                    </div>
                                    <p class="text-[10px] font-black text-orange-500">+10% Delivery Fee</p>
