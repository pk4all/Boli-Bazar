<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= auction.title %> | BoliBazar High-Impact Auction</title>
    <!-- Google Fonts: Inter & Outfit -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #d90429;
            --secondary: #1a1a1a;
            --accent: #ffb703;
            --success: #2ec4b6;
        }
        body { font-family: 'Inter', sans-serif; }
        .font-heading { font-family: 'Outfit', sans-serif; }
        
        /* Premium Background Gradient */
        .bg-detail-mesh {
            background-color: #f8fafc;
            background-image: radial-gradient(at 0% 0%, rgba(217, 4, 41, 0.05) 0px, transparent 50%),
                              radial-gradient(at 100% 0%, rgba(26, 26, 26, 0.02) 0px, transparent 50%);
        }

        .sticky-sidebar { position: sticky; top: 100px; }

        /* Countdown Banner Animation */
        .countdown-banner {
            background: linear-gradient(90deg, #d90429, #ef233c);
            animation: pulse-red 2s infinite;
        }
        @keyframes pulse-red {
            0% { box-shadow: 0 0 0 0 rgba(217, 4, 41, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(217, 4, 41, 0); }
            100% { box-shadow: 0 0 0 0 rgba(217, 4, 41, 0); }
        }

        /* Tabs Styling */
        .tab-btn { position: relative; padding-bottom: 12px; transition: all 0.3s; }
        .tab-btn.active { color: var(--primary); }
        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--primary);
            border-radius: 99px;
        }

        /* Leaderboard Cards */
        .leader-card {
            border: 1px solid #f1f5f9;
            transition: all 0.2s;
        }
        .leader-card:hover { border-color: var(--primary); transform: translateX(5px); }

        /* Custom Quantity Input */
        .qty-input::-webkit-inner-spin-button, 
        .qty-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }

        .payment-toggle {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
    </style>
</head>
<body class="bg-detail-mesh min-h-screen pb-24">
    <!-- Top Sticky Progress Bar (Glass) -->
    <div class="fixed top-0 left-0 w-full h-1 bg-gray-100 z-[200]">
        <div class="h-full bg-primary transition-all duration-300" style="width: <%= auction.stockSoldPercent %>%"></div>
    </div>

    <!-- Top Urgent Banner (Matches Screenshot) -->
    <div class="bg-red-500/90 backdrop-blur-sm py-2 text-white border-b border-red-600/20 z-[150] sticky top-0">
        <div class="container mx-auto px-4 flex items-center justify-center gap-3">
            <i class="fas fa-fire text-yellow-300 animate-pulse"></i>
            <span class="text-[11px] font-black uppercase tracking-wider">Sirf Ended bache hain! Abhi bid karein — jitni deri, utna mehenga.</span>
        </div>
    </div>

    <!-- Navigation Header (Matches Screenshot) -->
    <header class="bg-white border-b border-gray-100 z-[140] sticky top-[33px]">
        <div class="container mx-auto px-4 h-20 flex justify-between items-center">
            <!-- Logo Section -->
            <a href="/auctions" class="flex items-center gap-2">
                <div class="w-10 h-10 bg-gray-50 flex items-center justify-center rounded-xl overflow-hidden grayscale opacity-80">
                    <i class="fas fa-gavel text-secondary"></i>
                </div>
                <div class="flex flex-col -space-y-1">
                    <span class="text-2xl font-black tracking-tighter uppercase font-heading">Boli<span class="text-primary italic">Bazar</span></span>
                </div>
            </a>

            <!-- Nav Links -->
            <nav class="hidden lg:flex items-center gap-10">
                <a href="/auctions" class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-gray-500 hover:text-primary transition">
                    <i class="fas fa-bolt-lightning text-gray-300"></i> Live Auctions
                </a>
                <a href="/auctions" class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-gray-500 hover:text-primary transition">
                    <i class="far fa-clock text-gray-300"></i> Upcoming Lots
                </a>
                <a href="/dashboard" class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-gray-500 hover:text-primary transition">
                    <i class="fas fa-gavel text-gray-300"></i> My Bids
                </a>
            </nav>

            <!-- User Area -->
            <div class="flex items-center gap-6">
                <!-- Tokens -->
                <div class="bg-red-50 border border-red-100 px-4 py-2 rounded-xl flex items-center gap-3">
                    <i class="fas fa-wallet text-primary text-xs"></i>
                    <span class="text-[10px] font-black uppercase text-secondary">₹2,450 <span class="text-primary">Tokens</span></span>
                </div>
                <!-- Notifs -->
                <div class="relative">
                    <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-secondary relative hover:bg-gray-100 cursor-pointer transition">
                        <i class="far fa-bell"></i>
                        <span class="absolute -top-1 -right-1 w-4 h-4 bg-primary text-white text-[8px] font-black flex items-center justify-center rounded-full border-2 border-white">1</span>
                    </div>
                </div>
                <!-- User -->
                <div class="flex items-center gap-3 pl-2 border-l border-gray-100 group cursor-pointer">
                    <div class="w-10 h-10 rounded-xl bg-primary text-white flex items-center justify-center font-black text-sm shadow-lg shadow-red-500/20">
                        <%= (user ? user.username.charAt(0) : 'R').toUpperCase() %>
                    </div>
                    <div class="hidden sm:flex flex-col">
                        <span class="text-[10px] font-black text-secondary uppercase tracking-widest"><%= user ? user.username : 'Ramesh Gupta' %></span>
                        <i class="fas fa-chevron-down text-[8px] text-gray-300 mt-0.5"></i>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 mt-8">
        
        <!-- Breadcrumbs -->
        <div class="flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-gray-400 mb-8">
            <a href="/auctions" class="flex items-center gap-2 hover:text-primary transition">
                <i class="fas fa-arrow-left text-[8px]"></i> Live Auctions
            </a>
            <i class="fas fa-chevron-right text-[7px] opacity-30"></i>
            <span><%= auction.category || 'Grains & Cereals' %></span>
            <i class="fas fa-chevron-right text-[7px] opacity-30"></i>
            <span class="text-secondary opacity-60"><%= auction.title %></span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <!-- LEFT COLUMN (7/12) -->
            <div class="lg:col-span-8 space-y-8 pb-12">
                
                <!-- Product Banner (Matches Screenshot Overlay Style) -->
                <div class="relative rounded-[2.5rem] overflow-hidden aspect-[16/9] lg:aspect-video shadow-2xl group">
                    <img src="<%= auction.imageUrl || '/lot1.png' %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-[2s]">
                    
                    <!-- Top Labels -->
                    <div class="absolute top-8 left-8 flex gap-3">
                        <div class="px-4 py-2 bg-accent text-secondary rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2 shadow-xl">
                            <i class="fas fa-star"></i> Featured
                        </div>
                        <div class="px-4 py-2 bg-white/90 backdrop-blur-md text-secondary rounded-xl text-[10px] font-black uppercase tracking-widest shadow-xl">
                            <%= auction.category || 'Grains & Cereals' %>
                        </div>
                    </div>

                    <!-- Right Status (Countdown Look) -->
                    <div class="absolute top-8 right-8">
                        <div class="px-4 py-2 bg-[#b91c1c] text-white rounded-xl text-[11px] font-black uppercase tracking-wider flex items-center gap-2 shadow-2xl">
                            <i class="far fa-clock"></i> 03:39
                        </div>
                    </div>

                    <!-- Bottom Info Overlay -->
                    <div class="absolute bottom-0 left-0 w-full p-12 bg-gradient-to-t from-black/80 via-black/40 to-transparent">
                        <h2 class="text-4xl font-black text-white font-heading leading-tight mb-2"><%= auction.title %></h2>
                        <span class="text-xs font-bold text-white/60 uppercase tracking-widest">SKU: <%= (auction.category.slice(0,2) + '-' + auction.title.slice(0,4)).toUpperCase() %>-<%= auction._id.toString().slice(-4).toUpperCase() %></span>
                    </div>
                </div>


                
                <!-- Live Price Tracker Card (Matches Screenshot With Glow) -->
                <div class="bg-white rounded-[2.5rem] p-8 border border-gray-100 shadow-[0_20px_60px_rgba(217,4,41,0.12)]">
                    <div class="flex items-center justify-between mb-8">
                        <h4 class="text-xl font-black text-secondary">Live Price Tracker</h4>
                        <div class="flex items-center gap-2 text-emerald-500">
                            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
                            <span class="text-[11px] font-black uppercase tracking-widest">Real-time</span>
                        </div>
                    </div>

                    <!-- 2x2 Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                        <!-- Starting Price -->
                        <div class="bg-[#f8fafc] p-6 rounded-[2rem] border border-slate-100">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Starting Price</p>
                            <p class="text-3xl font-black text-slate-600">₹<%= auction.initialPrice.toLocaleString() %></p>
                        </div>
                        <!-- Current Price -->
                        <div class="bg-[#fff1f2] p-6 rounded-[2rem] border border-red-50">
                            <p class="text-[10px] font-black text-red-400 uppercase tracking-widest mb-2">Current Price</p>
                            <p class="text-3xl font-black text-[#9d174d]">₹<%= auction.currentBid.toLocaleString() %></p>
                        </div>
                        <!-- Total Buyers -->
                        <div class="bg-[#eff6ff] p-6 rounded-[2rem] border border-blue-50">
                            <p class="text-[10px] font-black text-blue-400 uppercase tracking-widest mb-2">Total Buyers</p>
                            <p class="text-3xl font-black text-indigo-600"><%= auction.totalBuyers %> buyers</p>
                        </div>
                        <!-- Remaining Stock -->
                        <div class="bg-[#fff7ed] p-6 rounded-[2rem] border border-orange-50">
                            <p class="text-[10px] font-black text-orange-400 uppercase tracking-widest mb-2">Remaining Stock</p>
                            <p class="text-3xl font-black text-[#c2410c]"><%= auction.stockRemaining %> <span class="text-sm uppercase"><%= auction.unitType %></span></p>
                        </div>
                    </div>

                    <!-- Stock Sold Section -->
                    <div class="space-y-4">
                        <div class="flex justify-between items-end">
                            <span class="text-sm font-bold text-gray-400">Stock Sold</span>
                            <span class="text-xs font-black text-[#b91c1c] uppercase tracking-widest">80% gone</span>
                        </div>
                        <div class="h-4 w-full bg-gray-100 rounded-full overflow-hidden">
                            <div class="h-full bg-primary rounded-full transition-all duration-1000" style="width: <%= auction.stockSoldPercent %>%"></div>
                        </div>
                        <p class="text-[11px] font-black text-primary flex items-center gap-2">
                            <i class="fas fa-info-circle text-xs"></i>
                            Sirf 41 bags bacha hai — jaldi karein!
                        </p>
                    </div>

                    <!-- Price Hike Footer -->
                    <div class="mt-8 bg-[#fefce8] p-5 rounded-2xl border border-yellow-100 flex justify-between items-center group">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-white/50 flex items-center justify-center text-yellow-600 transition group-hover:rotate-45">
                                <i class="fas fa-arrow-trend-up"></i>
                            </div>
                            <span class="text-xs font-black text-yellow-800 uppercase tracking-widest">Price Hike So Far</span>
                        </div>
                        <span class="text-lg font-black text-yellow-700 tracking-tighter">+<%= auction.hikePercentage %>%</span>
                    </div>
                </div>

                <!-- Tabs & Content -->
                <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-sm overflow-hidden">
                    <!-- Tab Headers -->
                    <div class="px-8 pt-6 border-b border-gray-100 flex gap-8">
                        <button class="tab-btn active text-xs font-black uppercase tracking-widest" onclick="switchTab('overview')">Overview</button>
                        <button class="tab-btn text-xs font-black uppercase tracking-widest" onclick="switchTab('specs')">Specifications</button>
                        <button class="tab-btn text-xs font-black uppercase tracking-widest" onclick="switchTab('history')">Bid Activity</button>
                    </div>
                    
                    <!-- Tab Panels -->
                    <div class="p-8">
                        <div id="overview-tab" class="tab-panel">
                            <h4 class="text-lg font-black mb-4">Product Overview</h4>
                            <p class="text-sm text-gray-500 leading-relaxed mb-10">
                                <%= auction.description || 'Premium factory-direct lot. No middleman — sourced directly from the manufacturer for maximum retail margins. Inspected and verified by BoliBazar quality team.' %>
                            </p>
                            
                            <!-- 4-Card Mini Stats Grid (Exact Parity) -->
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
                                <div class="bg-[#fafafa] p-5 rounded-[2rem] border border-gray-100 flex flex-col items-center text-center">
                                    <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-gray-400 mb-3 shadow-sm">
                                        <i class="fas fa-tag text-xs"></i>
                                    </div>
                                    <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Starting Price</p>
                                    <p class="text-sm font-black text-secondary">₹1,200</p>
                                </div>
                                <div class="bg-[#fafafa] p-5 rounded-[2rem] border border-gray-100 flex flex-col items-center text-center">
                                    <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-primary mb-3 shadow-sm">
                                        <i class="fas fa-chart-line text-xs"></i>
                                    </div>
                                    <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Price Hike</p>
                                    <p class="text-sm font-black text-primary">+9.19%</p>
                                </div>
                                <div class="bg-[#fafafa] p-5 rounded-[2rem] border border-gray-100 flex flex-col items-center text-center">
                                    <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-indigo-600 mb-3 shadow-sm">
                                        <i class="fas fa-users text-xs"></i>
                                    </div>
                                    <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Total Buyers</p>
                                    <p class="text-sm font-black text-indigo-600">9</p>
                                </div>
                                <div class="bg-[#fafafa] p-5 rounded-[2rem] border border-gray-100 flex flex-col items-center text-center">
                                    <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-orange-600 mb-3 shadow-sm">
                                        <i class="fas fa-cubes text-xs"></i>
                                    </div>
                                    <p class="text-[9px] font-black text-gray-400 uppercase tracking-widest mb-1">Remaining</p>
                                    <p class="text-sm font-black text-orange-600">41</p>
                                </div>
                            </div>

                            <!-- Mini Gallery Grid -->
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                                <div class="aspect-square bg-gray-50 rounded-2xl overflow-hidden border border-gray-100 group">
                                    <img src="<%= auction.imageUrl || '/lot1.png' %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                </div>
                            </div>
                        </div>

                        <div id="specs-tab" class="tab-panel hidden">
                            <h4 class="text-lg font-black mb-4">Technical Specifications</h4>
                            <div class="space-y-4">
                                <div class="flex justify-between py-3 border-b border-gray-50">
                                    <span class="text-xs font-bold text-gray-400 uppercase">Lot Weight / Unit</span>
                                    <span class="text-xs font-black text-secondary">50 KG Bag</span>
                                </div>
                                <div class="flex justify-between py-3 border-b border-gray-50">
                                    <span class="text-xs font-bold text-gray-400 uppercase">Minimum Order</span>
                                    <span class="text-xs font-black text-secondary"><%= auction.moq || 1 %> Bag</span>
                                </div>
                                <div class="flex justify-between py-3 border-b border-gray-50">
                                    <span class="text-xs font-bold text-gray-400 uppercase">GST Bracket</span>
                                    <span class="text-xs font-black text-secondary">5% Applicable</span>
                                </div>
                            </div>
                        </div>

                        <div id="history-tab" class="tab-panel hidden">
                            <h4 class="text-lg font-black mb-6">Real-Time Bidding Activity</h4>
                            <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2 no-scrollbar">
                                <% (locals.bidHistory || []).forEach(bid => { %>
                                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-2xl border border-gray-100">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-primary font-black shadow-sm">
                                                <%= bid.bidder.charAt(0) %>
                                            </div>
                                            <div>
                                                <p class="text-xs font-black text-secondary"><%= bid.bidder %></p>
                                                <p class="text-[9px] font-bold text-gray-400"><%= bid.time %></p>
                                            </div>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-sm font-black text-secondary">₹<%= bid.amount.toLocaleString() %></p>
                                            <p class="text-[9px] font-bold text-primary"><%= bid.quantity %> Bags</p>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Price Tracker Section -->
                <div class="bg-secondary rounded-[2.5rem] p-8 text-white relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-8">
                        <div class="px-4 py-1.5 bg-white/10 rounded-full text-[10px] font-black uppercase tracking-widest backdrop-blur-md">Price Trend</div>
                    </div>
                    <h4 class="text-xl font-black mb-1">Live Price Tracker</h4>
                    <p class="text-xs text-white/50 mb-10">Real-time demand visualization</p>
                    
                    <!-- Graph Mockup (SVG) -->
                    <div class="w-full h-48 mt-4 relative">
                        <svg class="w-full h-full" viewBox="0 0 1000 200" preserveAspectRatio="none">
                            <path d="M0,180 Q250,170 400,120 T700,80 T1000,20" fill="none" stroke="#d90429" stroke-width="6" stroke-linecap="round"></path>
                            <path d="M0,180 Q250,170 400,120 T700,80 T1000,20 L1000,200 L0,200 Z" fill="url(#grad1)" opacity="0.2"></path>
                            <defs>
                                <linearGradient id="grad1" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" style="stop-color:#d90429;stop-opacity:1" />
                                    <stop offset="100%" style="stop-color:#d90429;stop-opacity:0" />
                                </linearGradient>
                            </defs>
                        </svg>
                        <div class="absolute bottom-0 left-0 w-full flex justify-between px-2 text-[9px] font-bold text-white/30 uppercase tracking-widest mt-4">
                            <span>Started (₹<%= auction.initialPrice %>)</span>
                            <span>Highest (₹<%= auction.currentBid %>)</span>
                        </div>
                    </div>
                </div>

                <!-- Bid Leaderboard Section (Matches Screenshot) -->
                <div class="bg-white rounded-[2.5rem] p-8 border border-gray-100 shadow-xl mt-8">
                    <div class="flex items-center justify-between mb-8">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-yellow-50 flex items-center justify-center text-yellow-500">
                                <i class="fas fa-trophy text-lg"></i>
                            </div>
                            <div>
                                <h4 class="text-xl font-black text-secondary">Bid Leaderboard</h4>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Latest buyers — real-time</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 text-gray-300">
                            <i class="fas fa-sync-alt text-[10px] animate-spin-slow"></i>
                            <span class="text-[9px] font-black uppercase tracking-widest">Auto-updating</span>
                        </div>
                    </div>

                    <!-- Podium Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
                        <!-- #2 Sunita -->
                        <div class="bg-[#fffbeb] p-6 rounded-3xl border border-yellow-100 flex flex-col items-center text-center relative overflow-hidden group hover:scale-[1.02] transition-transform">
                            <div class="w-10 h-10 bg-yellow-400 rounded-full flex items-center justify-center text-white mb-3 shadow-lg relative z-10 border-2 border-white">
                                <i class="fas fa-medal text-sm"></i>
                            </div>
                            <h5 class="text-sm font-black text-secondary">Sunita</h5>
                            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-3">@ Bhopal</p>
                            <p class="text-base font-black text-primary">₹12,31,585.62</p>
                        </div>
                        <!-- #1 Harpreet (Highest) -->
                        <div class="bg-[#fffbeb] p-8 rounded-[2rem] border-2 border-yellow-200 flex flex-col items-center text-center relative overflow-hidden group hover:scale-[1.02] transition-transform md:-translate-y-2 shadow-lg">
                            <div class="w-12 h-12 bg-yellow-500 rounded-full flex items-center justify-center text-white mb-3 shadow-xl relative z-10 border-4 border-white">
                                <i class="fas fa-crown text-base"></i>
                            </div>
                            <h5 class="text-base font-black text-secondary">Harpreet</h5>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">@ Amritsar</p>
                            <p class="text-lg font-black text-primary">₹12,43,901.48</p>
                            <div class="absolute top-0 right-0 p-3">
                                <span class="w-2 h-2 bg-green-500 rounded-full animate-ping"></span>
                            </div>
                        </div>
                        <!-- #3 Arjun -->
                        <div class="bg-[#fffbeb] p-6 rounded-3xl border border-yellow-100 flex flex-col items-center text-center relative overflow-hidden group hover:scale-[1.02] transition-transform">
                            <div class="w-10 h-10 bg-yellow-400 rounded-full flex items-center justify-center text-white mb-3 shadow-lg relative z-10 border-2 border-white">
                                <i class="fas fa-award text-sm"></i>
                            </div>
                            <h5 class="text-sm font-black text-secondary">Arjun</h5>
                            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-3">@ Ahmedabad</p>
                            <p class="text-base font-black text-primary">₹12,19,391.70</p>
                        </div>
                    </div>

                    <!-- Bid List Layout -->
                    <div class="space-y-4 max-h-[400px] overflow-y-auto pr-4 custom-scrollbar">
                        <!-- Item 698 -->
                        <div class="flex items-center justify-between p-4 hover:bg-gray-50 rounded-2xl transition group">
                            <div class="flex items-center gap-4">
                                <span class="text-[10px] font-bold text-gray-300">#698</span>
                                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-500 font-black text-xs">H</div>
                                <div>
                                    <div class="flex items-center gap-2">
                                        <p class="text-xs font-black text-secondary">Harpreet Kaur</p>
