                                        <span class="text-[10px] font-black uppercase text-secondary">Full Payment</span>
                                    </div>
                                    <p class="text-[10px] font-black text-emerald-500">FREE Delivery</p>
                                    <p class="text-[8px] font-bold text-gray-400 mt-1">100% amount pay karein</p>
                                </div>
                                <div onclick="setPaymentMode('cod')" id="pay-cod" class="payment-card border-2 border-gray-100 rounded-2xl p-4 cursor-pointer transition hover:bg-gray-50 group">
