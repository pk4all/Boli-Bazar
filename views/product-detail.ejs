                                    <i class="fas fa-exclamation-circle text-[8px]"></i>
                                    Insufficient
                                </p>
                            </div>
                        </div>

                        <!-- Main Primary CTA -->
                        <div class="pt-2">
                            <button onclick="window.location.href='/auctions'" class="w-full bg-gradient-to-r from-[#d90429] to-[#ef233c] hover:opacity-90 text-white py-5 rounded-2xl text-[12px] font-black uppercase tracking-[0.2em] shadow-xl shadow-red-500/20 active:scale-95 transition-all flex items-center justify-center gap-4">
                                <i class="fas fa-bolt-lightning"></i>
                                Abhi Bid Lagao
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Payment & Delivery Policy Card -->
                <div class="bg-white rounded-[2rem] border border-gray-100 shadow-xl overflow-hidden mt-6">
                    <div class="p-6 border-b border-gray-50 flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center text-primary">
                            <i class="fas fa-shield-heart text-sm"></i>
                        </div>
                        <h4 class="text-sm font-black text-secondary uppercase tracking-widest">Payment & Delivery Policy</h4>
                    </div>
                    <div class="p-6 space-y-4">
                        <!-- 10% Advance -->
                        <div class="bg-[#eff6ff] p-4 rounded-2xl border border-blue-100 flex items-center gap-4 group hover:bg-blue-100 transition">
                            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-blue-600 shadow-sm transition-transform group-hover:scale-110">
                                <i class="fas fa-credit-card text-xs"></i>
                            </div>
                            <div>
                                <h5 class="text-xs font-black text-secondary">10% Advance Mandatory</h5>
                                <p class="text-[9px] font-bold text-gray-500 mt-0.5">Token balance se 10% advance kat jaata hai — booking confirm.</p>
                            </div>
                        </div>
                        <!-- Full Payment -->
                        <div class="bg-[#f0fdf4] p-4 rounded-2xl border border-green-100 flex items-center gap-4 group hover:bg-green-100 transition">
                            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-green-600 shadow-sm transition-transform group-hover:scale-110">
                                <i class="fas fa-truck-fast text-xs"></i>
                            </div>
                            <div>
                                <h5 class="text-xs font-black text-secondary">Full Payment = FREE Delivery</h5>
                                <p class="text-[9px] font-bold text-gray-500 mt-0.5">100% amount pay karein toh delivery bilkul free milegi.</p>
                            </div>
                        </div>
                        <!-- COD -->
                        <div class="bg-[#fffbeb] p-4 rounded-2xl border border-yellow-100 flex items-center gap-4 group hover:bg-yellow-100 transition">
                            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-yellow-600 shadow-sm transition-transform group-hover:scale-110">
                                <i class="fas fa-box text-xs"></i>
                            </div>
                            <div>
                                <h5 class="text-xs font-black text-secondary">COD = 10% Extra Charge</h5>
                                <p class="text-[9px] font-bold text-gray-500 mt-0.5">90% balance delivery pe + 10% extra delivery fee lagegi.</p>
