<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account | BoliBazar</title>
    
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#001f3f',
                        'secondary-dark': '#001021',
                    }
                }
            }
        }
    </script>
    <style>
        .hero-gradient {
            background: linear-gradient(135deg, #001f3f 0%, #001021 100%);
        }
        .feature-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 16px;
        }
        .login-container {
            min-height: 100vh;
        }
    </style>
</head>
<body class="bg-gray-50 font-sans">

    <div class="flex flex-col md:flex-row h-screen overflow-hidden">
        
        <!-- Left Side: Branding & Info -->
        <div class="md:w-1/2 lg:w-3/5 hero-gradient text-white p-8 lg:p-16 flex flex-col justify-between relative overflow-y-auto">
            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full -mr-64 -mt-64"></div>
            
            <div class="z-10">
                <div class="flex items-center space-x-3 mb-16">
                    <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg">
                        <i class="fas fa-gavel text-2xl"></i>
                    </div>
                    <div>
                        <h1 class="text-2xl font-black tracking-tighter uppercase leading-none">BoliBazar</h1>
                        <p class="text-[10px] font-bold text-primary tracking-widest uppercase text-right">Factory to Retailer Platform</p>
                    </div>
                </div>

                    <h2 class="text-4xl lg:text-6xl font-black mb-6 font-heading leading-tight underline decoration-primary decoration-4 underline-offset-8 text-white">
                        Join the <br><span class="text-primary italic">Retail Revolution.</span>
                    </h2>
                    <p class="text-lg text-blue-100 max-w-md mb-8 font-medium">
                        BoliBazar connects you directly to the source. No agents, no heavy commissions—just pure profit for your shop.
                    </p>

                    <!-- Trust Points -->
                    <div class="space-y-6 mb-12">
                        <div class="flex items-start space-x-4">
                            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 backdrop-blur-md border border-white/20">
                                <i class="fas fa-industry text-primary text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-lg">Direct from Factory</h4>
                                <p class="text-sm text-blue-200">Bypass 3-4 layers of wholesalers. Buy inventory at the price they buy.</p>
                            </div>
                        </div>
                        <div class="flex items-start space-x-4">
                            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 backdrop-blur-md border border-white/20">
                                <i class="fas fa-shield-alt text-primary text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-lg">Verified Bidding</h4>
                                <p class="text-sm text-blue-200">Only genuine manufacturers list their stock. Secured with 10% token protection.</p>
                            </div>
                        </div>
                        <div class="flex items-start space-x-4">
                            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 backdrop-blur-md border border-white/20">
                                <i class="fas fa-truck-loading text-primary text-xl"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-lg">Doorstep Delivery</h4>
                                <p class="text-sm text-blue-200">Across 150+ cities in India. We handle the logistics while you run your business.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Trust Stats -->
                    <div class="flex items-center space-x-6 mb-12 border-t border-white/10 pt-8">
                        <div class="flex -space-x-2">
                            <div class="w-8 h-8 rounded-full border border-secondary bg-gray-600 transition hover:z-10 hover:scale-110"></div>
                            <div class="w-8 h-8 rounded-full border border-secondary bg-gray-500 transition hover:z-10 hover:scale-110"></div>
                            <div class="w-8 h-8 rounded-full border border-secondary bg-gray-400 transition hover:z-10 hover:scale-110"></div>
                        </div>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-none">12,000+ Active Retailers</p>
                    </div>
                </div>

                <!-- Policy Alert -->
                <div class="bg-white/5 border border-white/10 p-6 rounded-3xl mt-auto">
                    <p class="text-[10px] text-gray-400 font-medium leading-relaxed">
                    By registering, you agree to our Retailer Policy and mandatory business verification to maintain platform integrity.
                    </p>
                </div>
            </div>

        <!-- Right Side: Registration Form -->
        <div class="md:w-1/2 lg:w-2/5 bg-white p-8 lg:p-16 flex flex-col justify-start items-center overflow-y-auto">
            <div class="w-full max-w-sm">
                
                <div class="bg-gray-100 p-1 rounded-2xl flex mb-12">
                    <a href="/login" class="flex-1 py-3 text-sm font-bold rounded-xl text-gray-400 hover:text-secondary transition text-center">Login</a>
                    <button class="flex-1 py-3 text-sm font-bold rounded-xl bg-white shadow-sm text-primary">Register</button>
                </div>

                <div class="mb-10">
                    <h3 class="text-4xl font-black mb-2 font-heading tracking-tight">Get Started</h3>
                    <p class="text-gray-400 text-sm font-medium">Create your business account today.</p>
                </div>

                <% if (error) { %>
                    <div class="bg-red-50 text-red-600 text-xs font-bold p-4 rounded-xl mb-6">
                        <%= error %>
                    </div>
                <% } %>

                <form action="/register" method="POST" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="md:col-span-2">
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">Full Name (Owner)</label>
                            <input type="text" name="username" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="John Doe">
                        </div>
                        <div class="md:col-span-2">
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">Shop Name</label>
                            <input type="text" name="shopName" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="e.g. Suraj Kirana Store">
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">Mobile Number</label>
                            <input type="tel" name="phone" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="+91 98765 43210">
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">Email Address <span class="text-gray-300 font-medium">(Optional)</span></label>
                            <input type="email" name="email" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="john@store.com">
                        </div>
                        <div class="md:col-span-2">
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">Shop Address</label>
                            <input type="text" name="address" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="House No, Street, Area">
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">City</label>
                            <input type="text" name="city" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="e.g. Lucknow">
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">State</label>
                            <select name="state" id="state" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition appearance-none">
                                <option value="">Select State</option>
                                <option value="Andaman and Nicobar Islands">Andaman and Nicobar Islands</option>
                                <option value="Andhra Pradesh">Andhra Pradesh</option>
                                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                                <option value="Assam">Assam</option>
                                <option value="Bihar">Bihar</option>
                                <option value="Chandigarh">Chandigarh</option>
                                <option value="Chhattisgarh">Chhattisgarh</option>
                                <option value="Dadra and Nagar Haveli and Daman and Diu">Dadra and Nagar Haveli and Daman and Diu</option>
                                <option value="Delhi">Delhi</option>
                                <option value="Goa">Goa</option>
                                <option value="Gujarat">Gujarat</option>
                                <option value="Haryana">Haryana</option>
                                <option value="Himachal Pradesh">Himachal Pradesh</option>
                                <option value="Jammu and Kashmir">Jammu and Kashmir</option>
                                <option value="Jharkhand">Jharkhand</option>
                                <option value="Karnataka">Karnataka</option>
                                <option value="Kerala">Kerala</option>
                                <option value="Ladakh">Ladakh</option>
                                <option value="Lakshadweep">Lakshadweep</option>
                                <option value="Madhya Pradesh">Madhya Pradesh</option>
                                <option value="Maharashtra">Maharashtra</option>
                                <option value="Manipur">Manipur</option>
                                <option value="Meghalaya">Meghalaya</option>
                                <option value="Mizoram">Mizoram</option>
                                <option value="Nagaland">Nagaland</option>
                                <option value="Odisha">Odisha</option>
                                <option value="Puducherry">Puducherry</option>
                                <option value="Punjab">Punjab</option>
                                <option value="Rajasthan">Rajasthan</option>
                                <option value="Sikkim">Sikkim</option>
                                <option value="Tamil Nadu">Tamil Nadu</option>
                                <option value="Telangana">Telangana</option>
                                <option value="Tripura">Tripura</option>
                                <option value="Uttar Pradesh">Uttar Pradesh</option>
                                <option value="Uttarakhand">Uttarakhand</option>
                                <option value="West Bengal">West Bengal</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">Pin Code</label>
                            <input type="text" name="pincode" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="226001">
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-1 ml-2 tracking-widest">Password</label>
                            <input type="password" name="password" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="••••••••">
                        </div>
                        <div class="md:col-span-2">
                            <label class="text-[10px] font-black text-blue-400 uppercase block mb-1 ml-2 tracking-widest">Sales Executive ID (Optional)</label>
                            <input type="text" name="executiveCode" class="w-full bg-blue-50 border border-blue-100 rounded-2xl px-6 py-3.5 text-sm font-bold focus:outline-none focus:border-blue-500 transition text-blue-800 placeholder-blue-300" placeholder="e.g. SE1234">
                            <p class="text-[9px] font-bold text-gray-400 ml-2 mt-1">If a Boli Bazar Sales Executive referred you, enter their code here.</p>
                        </div>
                    </div>

                    <button type="submit" class="w-full btn-primary py-4 rounded-2xl text-sm font-black uppercase tracking-[0.2em] shadow-xl shadow-red-100 mt-6">
                        Register My Shop <i class="fas fa-store ml-2"></i>
                    </button>
                </form>

                <p class="mt-8 text-center text-xs font-bold text-gray-400 leading-relaxed">
                    Already have an account? <a href="/login" class="text-primary hover:underline">Sign In</a>
                </p>
            </div>
        </div>

    </div>

    <script>
        const pincodeInput = document.querySelector('input[name="pincode"]');
        const cityInput = document.querySelector('input[name="city"]');
        const stateSelect = document.querySelector('select[name="state"]');

        pincodeInput.addEventListener('input', async (e) => {
            const pincode = e.target.value.replace(/\D/g, ''); // Remove non-digits
            if (pincode.length === 6) {
                pincodeInput.classList.add('opacity-50');
                try {
                    const response = await fetch(`https://api.postalpincode.in/pincode/${pincode}`);
                    const data = await response.json();
                    
                    if (data && data[0] && data[0].Status === 'Success') {
                        const postOffice = data[0].PostOffice[0];
                        cityInput.value = postOffice.District;
                        
                        // Select state in dropdown
                        let state = postOffice.State;
                        // Handle special cases for API vs Dropdown naming
                        if (state.toLowerCase().includes('delhi')) state = 'Delhi';
                        
                        let found = false;
                        for (let i = 0; i < stateSelect.options.length; i++) {
                            const optionValue = stateSelect.options[i].value.toLowerCase();
                            if (optionValue === state.toLowerCase() || state.toLowerCase().includes(optionValue)) {
                                stateSelect.selectedIndex = i;
                                found = true;
                                break;
                            }
                        }
                        if (!found) console.warn('State not found in dropdown:', state);
                    }
                } catch (error) {
                    console.error('Error fetching pincode details:', error);
                } finally {
                    pincodeInput.classList.remove('opacity-50');
                }
            }
        });
    </script>
</body>
</html>
