<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Executive Dashboard | BoliBazar Retailer</title>
    <!-- Google Fonts: Inter & Outfit -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#1a1a1a',
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --primary: #d90429;
            --secondary: #1a1a1a;
            --accent: #ffb703;
            --success: #2ec4b6;
            --glass: rgba(255, 255, 255, 0.9);
        }
        body { 
            font-family: 'Inter', sans-serif; 
            background: #f8fafc;
            background-image: radial-gradient(at 0% 0%, rgba(217, 4, 41, 0.03) 0px, transparent 50%),
                              radial-gradient(at 100% 0%, rgba(26, 26, 26, 0.01) 0px, transparent 50%);
        }
        .font-heading { font-family: 'Outfit', sans-serif; }
        
        .glass-card {
            background: var(--glass);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
        }

        .premium-gradient {
            background: linear-gradient(135deg, #d90429 0%, #ef233c 100%);
        }

        .stat-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }

        /* Profile Hover Effect */
        .profile-container:hover .profile-overlay {
            opacity: 1;
        }

        .custom-scrollbar::-webkit-scrollbar { width: 5px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #d90429; border-radius: 10px; }

        .premium-shadow {
            box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        }

        /* Tracking Timeline */
        .timeline-container {
            position: relative;
            padding-left: 2rem;
        }
        .timeline-container::before {
            content: '';
            position: absolute;
            left: 7px;
            top: 0;
            height: 100%;
            width: 2px;
            background: #f1f5f9;
        }
        .timeline-item {
            position: relative;
            padding-bottom: 2rem;
        }
        .timeline-dot {
            position: absolute;
            left: -2rem;
            width: 16px;
            height: 16px;
            background: white;
            border: 3px solid #cbd5e1;
            border-radius: 50%;
            z-index: 10;
        }
        .timeline-item.active .timeline-dot {
            border-color: #d90429;
            background: #d90429;
            box-shadow: 0 0 10px rgba(217, 4, 41, 0.4);
        }
        .timeline-item.completed .timeline-dot {
            border-color: #10b981;
            background: #10b981;
        }

        .animate-float {
            animation: float 3s ease-in-out infinite;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>
<body class="min-h-screen pb-12">

    <!-- Standardized Header (High Z-Index & Clickable) -->
    <nav class="sticky top-0 z-[2000] bg-white/90 backdrop-blur-md border-b border-gray-100">
        <div class="container mx-auto px-6 h-20 flex justify-between items-center">
            <a href="<%= (locals.viewMode === 'admin') ? '/admin' : '/auctions' %>" class="flex items-center gap-2">
                <span class="text-2xl font-black tracking-tighter uppercase font-heading" style="color: #1a1a1a;">Boli<span class="italic" style="color: #d90429;">Bazar</span></span>
            </a>
            <div class="flex items-center gap-8">
                <% if (locals.viewMode === 'admin') { %>
                    <a href="/admin" class="text-[10px] font-black uppercase tracking-widest text-primary hover:opacity-80 transition flex items-center gap-2">
                        <i class="fas fa-arrow-left"></i> Back to Command Center
                    </a>
                <% } else { %>
                    <a href="/auctions" class="text-[10px] font-black uppercase tracking-widest text-gray-400 hover:text-primary transition flex items-center gap-2">
                        <i class="fas fa-bolt-lightning text-gray-200"></i> Live Auctions
                    </a>
                <% } %>
                <div class="h-6 w-[1px] bg-gray-100"></div>
                <div class="flex items-center gap-4">
                    <div class="text-right hidden sm:block">
                        <p class="text-[10px] font-black text-secondary uppercase tracking-widest"><%= (locals.user && user.username) ? user.username : 'Retailer' %></p>
                        <p class="text-[8px] font-bold text-primary uppercase"><%= (locals.viewMode === 'admin') ? 'Viewing as Admin' : 'Elite Retailer' %></p>
                    </div>
                    <% if (locals.viewMode !== 'admin') { %>
                        <a href="/logout" class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-gray-400 hover:text-primary transition group">
                            <i class="fas fa-power-off group-hover:rotate-90 transition-transform"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-6 mt-10 relative z-10">
        <% 
            const d_rank = locals.rank || 0;
            const d_topFive = locals.topFive || [];
            const d_gap = locals.gapToTop3 || 0;
            const d_total = locals.totalRetailers || 1;
        %>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- LEFT COLUMN: Profile & Key Stats (4/12) -->
            <div class="lg:col-span-4 space-y-8">
                
                <!-- Profile Master Card -->
                <div class="glass-card rounded-[3rem] p-12 text-center relative overflow-hidden premium-shadow border-white/40">
                    <div class="absolute -top-24 -left-24 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>
                    <div class="absolute -bottom-24 -right-24 w-48 h-48 bg-indigo-500/10 rounded-full blur-3xl"></div>
                    
                    <!-- Profile Picture Section -->
                    <div class="relative w-36 h-36 mx-auto mb-8 profile-container group animate-float">
                        <div class="w-full h-full rounded-[2.5rem] overflow-hidden border-8 border-white shadow-2xl relative bg-slate-50 flex items-center justify-center text-slate-300 text-6xl font-black">
                            <% if (user.profileImage) { %>
                                <img src="<%= user.profileImage %>" class="w-full h-full object-cover">
                            <% } else { %>
                                <span class="opacity-10"><i class="fas fa-user"></i></span>
                            <% } %>
                        </div>
                        
                        <!-- Upload Overlay -->
                        <% if (locals.viewMode !== 'admin') { %>
                            <form action="/dashboard/update-profile" method="POST" enctype="multipart/form-data" class="absolute inset-0 flex items-center justify-center bg-slate-900/40 rounded-[2.5rem] opacity-0 group-hover:opacity-100 transition-all duration-500 cursor-pointer backdrop-blur-sm">
                                <label for="profileImgInput" class="cursor-pointer text-white flex flex-col items-center">
                                    <i class="fas fa-camera text-2xl mb-2"></i>
                                    <span class="text-[9px] font-black uppercase tracking-widest">Update Photo</span>
                                </label>
                                <input type="file" id="profileImgInput" name="profileImage" class="hidden" onchange="this.form.submit()">
                            </form>
                        <% } %>
                    </div>

                    <h2 class="text-3xl font-black font-heading text-slate-800 tracking-tight leading-none mb-2"><%= (locals.user && user.username) ? user.username : 'User' %></h2>
                    <p class="text-[11px] font-black text-primary uppercase tracking-[0.3em] mb-8 flex items-center justify-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                        <%= (locals.user && user.shopName) ? user.shopName : 'Shop' %>
                    </p>
                    
                    <div class="inline-flex items-center gap-2 px-6 py-2 bg-emerald-50 text-emerald-600 rounded-full text-[10px] font-black uppercase tracking-widest border border-emerald-100 mb-10">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        Verified Partner
                    </div>

                    <!-- Rank Stats Row -->
                    <div class="grid grid-cols-2 gap-0 border-t border-slate-100 pt-8">
                        <div class="pr-6 border-r border-slate-100">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Global Rank</p>
                            <p class="text-2xl font-black text-slate-800">#<%= d_rank > 0 ? d_rank : '--' %></p>
                        </div>
                        <div class="pl-6">
                            <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1.5">Elite Status</p>
                            <p class="text-2xl font-black text-primary italic"><%= (d_rank > 0 && d_rank <= 3) ? 'Gold' : 'Silver' %></p>
                        </div>
                    </div>
                </div>

                <!-- Coin Wallet (Creative Design) -->
                <div class="premium-gradient rounded-[2.5rem] p-10 text-white shadow-2xl shadow-red-500/30 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-8 opacity-20 group-hover:rotate-12 transition-transform">
                        <i class="fas fa-coins text-6xl"></i>
                    </div>
                    <div class="relative z-10">
                        <p class="text-[10px] font-black text-white/80 uppercase tracking-widest mb-2">Total Shopping Coins</p>
                        <h3 class="text-4xl font-black mb-10 tracking-tighter"><i class="fas fa-coins text-yellow-500 mr-2"></i><%= (user.walletBalance) ? user.walletBalance.toLocaleString() : '0' %></h3>
                        
                        <div class="flex items-center gap-4">
                            <div class="flex-grow py-4 px-6 border border-white/20 rounded-2xl bg-white/10 text-[10px] font-black uppercase tracking-widest flex items-center justify-between">
                                <span>Status: Elite Rewards</span>
                                <i class="fas fa-shield-check"></i>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center cursor-pointer hover:bg-white/30 transition shadow-xl text-white">
                                <i class="fas fa-history text-xs"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Smart Opinion Card (Fixed Contrast) -->
                <div class="bg-[#001f3f] rounded-[2.5rem] p-8 text-white relative overflow-hidden shadow-2xl shadow-gray-900/40">
                    <div class="absolute -top-4 -right-4 w-24 h-24 bg-primary/20 rounded-full blur-2xl"></div>
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center text-primary">
                            <i class="fas fa-lightbulb"></i>
                        </div>
                        <h4 class="text-xs font-black uppercase tracking-widest">Retailer Insight</h4>
                    </div>
                    
                    <div class="space-y-6">
                        <% if (d_rank > 3) { %>
                            <div>
                                <p class="text-[11px] font-medium text-white/80 leading-relaxed mb-4">
                                    Aap sirf <span class="text-white font-bold">₹<%= d_gap.toLocaleString() %></span> ki aur shopping karein toh aap <span class="text-primary font-black uppercase">Top 3</span> mein aa jayenge!
                                </p>
                                <div class="w-full bg-white/5 h-2 rounded-full overflow-hidden">
                                    <div class="h-full bg-primary" style="width: <%= (locals.user && d_gap >= 0) ? Math.min(100, (user.walletBalance / (user.walletBalance + d_gap) * 100)) : '0' %>%"></div>
                                </div>
                            </div>
                        <% } else if (d_rank > 0 && d_rank <= 3) { %>
                            <p class="text-[11px] font-medium text-white/60 leading-relaxed mb-4">
                                Excellent! Aap pehle se hi <span class="text-primary font-black uppercase">Top 3 Retailers</span> mein hain. Aapka trust humara sabse bada asset hai.
                            </p>
                        <% } else { %>
                            <p class="text-[11px] font-medium text-white/60 leading-relaxed mb-4">
                                Bidding start karein leaderboard mein apni jagah banane ke liye!
                            </p>
                        <% } %>

                        <div class="p-4 bg-white/5 rounded-2xl border border-white/10">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-[9px] font-black uppercase text-white/40">Profit Margin Advantage</span>
                                <span class="text-[10px] font-black text-green-400">+<%= (locals.userProfitMargin && locals.avgProfitMargin) ? (userProfitMargin - avgProfitMargin).toFixed(1) : '6.1' %>%</span>
                            </div>
                            <p class="text-[10px] font-medium text-white/80">
                                Aapka selection strategy kaafi accha hai, industry average se <%= locals.userProfitMargin || '18.5' %>% zyada profit kama rahe hain.
                            </p>
                        </div>
                    </div>
                </div>

            </div>
            <!-- RIGHT COLUMN: Main Interaction (8/12) -->
            <div class="lg:col-span-8 space-y-10">
                
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
                    <div class="glass-card p-6 rounded-[2rem] border border-gray-100/50 hover:border-primary/20 transition-all stat-card">
                        <div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center text-primary mb-3 shadow-sm">
                            <i class="fas fa-hammer text-xs"></i>
                        </div>
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Active Bids</p>
                        <p class="text-xl font-black text-secondary"><%= user.bids.length %></p>
                    </div>
                    <div class="glass-card p-6 rounded-[2rem] border border-gray-100/50 hover:border-green-400/20 transition-all stat-card">
                        <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-500 mb-3 shadow-sm">
                            <i class="fas fa-box text-xs"></i>
                        </div>
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Won Lots</p>
                        <p class="text-xl font-black text-secondary"><%= orders.length %></p>
                    </div>
                    <div class="glass-card p-6 rounded-[2rem] border border-gray-100/50 hover:border-blue-400/20 transition-all stat-card">
                        <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-500 mb-3 shadow-sm">
                            <i class="fas fa-hand-holding-heart text-xs"></i>
                        </div>
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Total Savings</p>
                        <p class="text-xl font-black text-secondary">~25% Extra</p>
                    </div>
                    <div class="glass-card p-6 rounded-[2rem] border border-gray-100/50 hover:border-primary/20 transition-all stat-card">
                        <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-500 mb-3 shadow-sm">
                            <i class="fas fa-shield-heart text-xs"></i>
                        </div>
                        <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Trust Score</p>
                        <p class="text-xl font-black text-secondary">9.8/10</p>
                    </div>
                </div>

                <!-- Financial Statement Summary -->
                <div class="bg-slate-900 rounded-[2.5rem] p-10 mb-12 shadow-2xl relative overflow-hidden text-white">
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/20 rounded-full blur-3xl"></div>
                    <div class="flex flex-col md:flex-row justify-between items-center gap-10 relative z-10">
                        <div class="text-center md:text-left">
                            <p class="text-[10px] font-black text-white/40 uppercase tracking-[0.3em] mb-2">Total Order Value</p>
                            <h3 class="text-3xl font-black font-heading leading-none">₹<%= financials.totalPurchased.toLocaleString() %></h3>
                        </div>
                        <div class="w-px h-12 bg-white/10 hidden md:block"></div>
                        <div class="text-center md:text-left">
                            <p class="text-[10px] font-black text-emerald-400 uppercase tracking-[0.3em] mb-2">Paid Amount</p>
                            <h3 class="text-3xl font-black font-heading text-emerald-400 leading-none">₹<%= financials.totalPaid.toLocaleString() %></h3>
                        </div>
                        <div class="w-px h-12 bg-white/10 hidden md:block"></div>
                        <div class="text-center md:text-left">
                            <p class="text-[10px] font-black text-orange-400 uppercase tracking-[0.3em] mb-2">Balance at COD</p>
                            <h3 class="text-3xl font-black font-heading text-orange-400 leading-none">₹<%= financials.balanceDue.toLocaleString() %></h3>
                        </div>
                    </div>
                </div>

                <!-- Section: My Winning Lots (Recent Orders) -->
                <section id="winning-lots">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h3 class="text-2xl font-black font-heading text-secondary">Winning <span class="text-primary italic">Lots</span></h3>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mt-1">Your successful acquisitions</p>
                        </div>
                        <a href="#winning-lots" class="text-[10px] font-black uppercase text-primary tracking-widest hover:translate-x-1 transition-transform inline-flex items-center gap-2">View All Orders <i class="fas fa-arrow-right text-[8px]"></i></a>
                    </div>

                    <% if (orders && orders.length > 0) { %>
                        <div class="space-y-4">
                            <% orders.forEach(order => { 
                                const auction = order.auction || { title: 'Deleted Product', imageUrl: '/lot1.png' };
                            %>
                                <div class="glass-card rounded-3xl p-6 border border-gray-100 flex flex-col md:flex-row md:items-center justify-between group hover:border-primary/30 transition-all overflow-hidden relative gap-6">
                                    <div class="absolute -right-4 -bottom-4 opacity-[0.03] group-hover:rotate-12 transition-transform duration-700">
                                        <i class="fas fa-shopping-cart text-8xl text-secondary"></i>
                                    </div>
                                    
                                    <div class="flex items-center gap-6 relative z-10 flex-grow">
                                        <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl overflow-hidden shadow-lg border-2 border-white flex-shrink-0">
                                            <img src="<%= auction.images && auction.images[0] ? auction.images[0] : (auction.imageUrl || '/lot1.png') %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-1000">
                                        </div>
                                        <div>
                                            <div class="flex flex-wrap items-center gap-3 mb-1">
                                                <h4 class="font-black text-secondary group-hover:text-primary transition"><%= auction.title %></h4>
                                                <span class="px-2 py-0.5 <%= order.status === 'Delivered' ? 'bg-green-50 text-green-600' : 'bg-blue-50 text-blue-600' %> rounded-md text-[8px] font-black uppercase tracking-widest">
                                                    <%= order.status %>
                                                </span>
                                            </div>
                                            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-3">Order ID: BZ-<%= order._id.toString().slice(-6).toUpperCase() %></p>
                                            <div class="flex items-center gap-4 text-[10px] font-black">
                                                <span class="text-secondary tracking-tighter">Budget: ₹<%= order.totalAmount.toLocaleString() %></span>
                                                <span class="text-gray-300">•</span>
                                                <span class="text-gray-500 uppercase tracking-widest font-bold"><%= order.quantity %> Units Won</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-3 relative z-10">
                                        <button onclick="downloadReceipt('<%= order._id %>', '<%= auction.title.replace(/'/g, "\\'") %>', <%= order.totalAmount %>, <%= order.quantity %>, 'Unit')" class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 hover:bg-secondary hover:text-white transition shadow-sm border border-slate-100" title="Download Receipt">
                                            <i class="fas fa-file-invoice text-xs"></i>
                                        </button>
                                        <button onclick="trackOrder('<%= order._id %>')" class="bg-primary text-white px-6 py-3 rounded-xl text-[9px] font-black uppercase tracking-widest shadow-xl shadow-red-500/20 hover:scale-105 transition-all">
                                            Track Order
                                        </button>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-20 bg-slate-50/50 rounded-[3rem] border border-dashed border-slate-200">
                            <i class="fas fa-box-open text-5xl text-slate-200 mb-4 block"></i>
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest">Abhi tak koi winning lot nahi hai</p>
                            <a href="/auctions" class="inline-flex items-center gap-3 bg-secondary text-white px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-primary transition shadow-xl mt-8">
                                Start Bidding Now
                            </a>
                        </div>
                    <% } %>
                </section>

                <!-- Section: Global Leaderboard (Top 5 Preview) -->
                <section>
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h3 class="text-2xl font-black font-heading text-secondary">Elite <span class="text-[#ffb703] italic">Leaderboard</span></h3>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mt-1">Top performing retailers this month</p>
                        </div>
                    </div>

                    <div class="glass-card rounded-[2.5rem] p-8 border border-gray-100">
                        <div class="space-y-4">
                            <% if (locals.topFive && topFive.length > 0) { %>
                                <% topFive.forEach((retailer, idx) => { %>
                                    <div class="flex items-center justify-between p-4 rounded-2xl transition-all <%= retailer._id.toString() === user._id.toString() ? 'bg-red-50/50 border border-red-100' : 'hover:bg-gray-50' %>">
                                        <div class="flex items-center gap-4">
                                            <span class="w-6 text-[10px] font-black <%= idx < 3 ? 'text-primary' : 'text-gray-300' %>">#0<%= idx + 1 %></span>
                                            <div class="w-10 h-10 rounded-xl overflow-hidden bg-gray-100 text-gray-400 flex items-center justify-center font-black text-xs">
                                                <% if (retailer.profileImage) { %>
                                                    <img src="<%= retailer.profileImage %>" class="w-full h-full object-cover">
                                                <% } else { %>
                                                    <%= retailer.username.charAt(0).toUpperCase() %>
                                                <% } %>
                                            </div>
                                            <div>
                                                <p class="text-xs font-black text-secondary"><%= retailer.username %> <%= retailer._id.toString() === user._id.toString() ? '(You)' : '' %></p>
                                                <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest"><%= retailer.city %></p>
                                            </div>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-xs font-black text-secondary"><i class="fas fa-coins text-yellow-500 mr-0.5"></i><%= retailer.walletBalance.toLocaleString() %></p>
                                            <p class="text-[8px] font-black text-primary uppercase tracking-widest">Shopping Coins</p>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="py-12 text-center">
                                    <div class="w-16 h-16 rounded-full bg-gray-50 flex items-center justify-center mx-auto mb-4 text-gray-200">
                                        <i class="fas fa-users-slash text-2xl"></i>
                                    </div>
                                    <p class="text-[10px] font-black uppercase text-gray-400 tracking-widest">No Competitors Found</p>
                                    <p class="text-[9px] text-gray-300 font-bold mt-1">Be the first to reach the top!</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </section>

            </div>

        </div>

    </main>

    <!-- Bottom Spacing -->
    <div class="h-12"></div>

    <!-- Tracking Modal -->
    <div id="trackingModal" class="fixed inset-0 z-[3000] hidden flex items-center justify-center p-6">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeTrackingModal()"></div>
        <div class="bg-white w-full max-w-lg rounded-[2.5rem] relative z-10 overflow-hidden shadow-2xl animate-in zoom-in duration-300">
            <div class="premium-gradient p-8 text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 p-8 opacity-20">
                    <i class="fas fa-truck-fast text-6xl"></i>
                </div>
                <div class="relative z-10">
                    <h3 class="text-2xl font-black font-heading mb-1">Track Your Order</h3>
                    <p class="text-[10px] font-black uppercase tracking-widest text-white/60" id="trackingID">ID: BZ-549D32</p>
                </div>
            </div>
            <div class="p-8">
                <div class="flex items-center gap-4 mb-8 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center text-primary shadow-sm">
                        <i class="fas fa-box"></i>
                    </div>
                    <div>
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Delivery Partner</p>
                        <p class="text-sm font-black text-slate-800">Delhivery Express — <span class="text-primary italic">Fastest</span></p>
                    </div>
                </div>

                <div class="timeline-container ml-2">
                    <div class="timeline-item completed">
                        <div class="timeline-dot"></div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Order Placed</p>
                        <p class="text-xs font-bold text-slate-600">Inventory reserved and payment confirmed.</p>
                        <p class="text-[9px] text-slate-400 mt-1">20 Oct, 2026 • 10:30 AM</p>
                    </div>
                    <div class="timeline-item active">
                        <div class="timeline-dot"></div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">In Transit</p>
                        <p class="text-xs font-bold text-slate-600">Material dispatched from Boli Bazar Hub.</p>
                        <p class="text-[9px] text-slate-400 mt-1">22 Oct, 2026 • 02:15 PM</p>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-dot"></div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Out for Delivery</p>
                        <p class="text-xs font-bold text-slate-300 italic">Expect delivery by tomorrow evening.</p>
                    </div>
                    <div class="timeline-item pb-0">
                        <div class="timeline-dot"></div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Delivered</p>
                        <p class="text-xs font-bold text-slate-300 italic">Shipment reached destination.</p>
                    </div>
                </div>

                <button onclick="closeTrackingModal()" class="w-full mt-10 py-4 bg-slate-900 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-black transition">Close Tracker</button>
            </div>
        </div>
    </div>

    <script>
        function toggleScheduling(val) {
            const scheduleDiv = document.getElementById('startSchedule');
            if (val === 'Upcoming') {
                scheduleDiv.classList.remove('hidden');
                scheduleDiv.querySelectorAll('input').forEach(i => i.required = true);
            } else {
                scheduleDiv.classList.add('hidden');
                scheduleDiv.querySelectorAll('input').forEach(i => i.required = false);
            }
        }

        function trackOrder(orderId) {
            document.getElementById('trackingID').innerText = `ID: BZ-${orderId.slice(-6).toUpperCase()}`;
            document.getElementById('trackingModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeTrackingModal() {
            document.getElementById('trackingModal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function downloadReceipt(orderId, title, price, qty, unit) {
            const receiptWindow = window.open('', '_blank');
            const date = new Date().toLocaleDateString('en-IN');
            
            const html = `
                <!DOCTYPE html>
                <html>
                <head>
                    <title>Invoice BZ-${orderId.slice(-6).toUpperCase()}</title>
                    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
                    <style>
                        body { font-family: 'Inter', sans-serif; padding: 40px; color: #1a1a1a; }
                        .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #f1f5f9; padding-bottom: 20px; }
                        .logo { font-weight: 900; font-size: 24px; text-transform: uppercase; letter-spacing: -1px; }
                        .logo span { color: #d90429; font-style: italic; }
                        .invoice-info { text-align: right; }
                        .table { width: 100%; border-collapse: collapse; margin-top: 40px; }
                        .table th { text-align: left; background: #f8fafc; padding: 15px; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #64748b; }
                        .table td { padding: 15px; border-bottom: 1px solid #f1f5f9; }
                        .total-section { margin-top: 40px; text-align: right; font-weight: 900; font-size: 20px; }
                        .footer { margin-top: 100px; text-align: center; color: #94a3b8; font-size: 10px; text-transform: uppercase; letter-spacing: 2px; }
                    </style>
                </head>
                <body>
                    <div class="header">
                        <div class="logo">Boli<span>Bazar</span></div>
                        <div class="invoice-info">
                            <p style="font-weight: 900; margin: 0;">INVOICE</p>
                            <p style="font-size: 10px; color: #64748b; margin: 5px 0 0;">#${orderId.slice(-6).toUpperCase()}</p>
                            <p style="font-size: 10px; color: #64748b; margin: 2px 0 0;">Date: ${date}</p>
                        </div>
                    </div>
                    <div style="margin-top: 40px;">
                        <p style="font-size: 10px; font-weight: 900; color: #64748b; text-transform: uppercase;">Billed To:</p>
                        <p style="font-weight: 900; margin: 5px 0 0;"><%= user.username %></p>
                        <p style="font-size: 12px; color: #64748b; margin: 2px 0 0;"><%= user.shopName %></p>
                        <p style="font-size: 12px; color: #64748b; margin: 2px 0 0;"><%= user.address %>, <%= user.city %></p>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Item Description</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th style="text-align: right;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="font-weight: 700;">${title}</td>
                                <td>${qty} ${unit}s</td>
                                <td>₹${price.toLocaleString()}</td>
                                <td style="text-align: right; font-weight: 700;">₹${(price).toLocaleString()}</td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="total-section">
                        <span style="font-size: 12px; color: #94a3b8; margin-right: 20px;">GRAND TOTAL:</span>
                        ₹${(price).toLocaleString()}
                    </div>
                    <div class="footer">
                        *** This is a computer generated invoice and requires no signature ***<br>
                        Thank you for your business with BoliBazar!
                    </div>
                    <script>window.print();<\/script>
                </body>
                </html>
            `;
            
            receiptWindow.document.write(html);
            receiptWindow.document.close();
        }
    </script>

</body>
</html>
