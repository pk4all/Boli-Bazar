<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manufacturer Registration | BoliBazar</title>
    
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#001f3f',
                        'secondary-dark': '#001021',
                    }
                }
            }
        }
    </script>
    <style>
        .hero-gradient {
            background: linear-gradient(135deg, #001f3f 0%, #001021 100%);
        }
        .form-container {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.95);
        }
    </style>
</head>
<body class="bg-gray-50 font-sans">

    <div class="flex flex-col md:flex-row min-h-screen overflow-hidden">
        
        <!-- Left Side: Branding & Info -->
        <div class="hidden md:flex md:w-1/3 lg:w-2/5 hero-gradient text-white p-12 lg:p-16 flex-col justify-between relative overflow-hidden">
            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full -mr-64 -mt-64"></div>
            
            <div class="z-10">
                <a href="/" class="flex items-center space-x-3 mb-16">
                    <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg">
                        <i class="fas fa-gavel text-2xl"></i>
                    </div>
                    <div>
                        <h1 class="text-2xl font-black tracking-tighter uppercase leading-none">BoliBazar</h1>
                        <p class="text-[10px] font-bold text-primary tracking-widest uppercase text-right">Manufacturer Gateway</p>
                    </div>
                </a>

                <h2 class="text-4xl lg:text-5xl font-black mb-6 font-heading leading-tight underline decoration-primary decoration-4 underline-offset-8 text-white">
                    Expand Your <br><span class="text-primary italic">Distribution Reach.</span>
                </h2>
                <p class="text-lg text-blue-100 max-w-sm mb-12 font-medium">
                    Connect with 12,000+ verified retailers directly. Liquidate your stock faster and reach new markets.
                </p>

                <div class="space-y-8">
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center border border-white/20">
                            <i class="fas fa-chart-line text-primary"></i>
                        </div>
                        <p class="text-sm font-bold">Real-time Demand Analytics</p>
                    </div>
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center border border-white/20">
                            <i class="fas fa-truck-fast text-primary"></i>
                        </div>
                        <p class="text-sm font-bold">Secure Logistics Support</p>
                    </div>
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center border border-white/20">
                            <i class="fas fa-shield-check text-primary"></i>
                        </div>
                        <p class="text-sm font-bold">Pre-verified Retailer Network</p>
                    </div>
                </div>
            </div>

            <div class="z-10 bg-white/5 border border-white/10 p-6 rounded-3xl mt-12">
                <p class="text-[10px] text-gray-400 font-medium leading-relaxed uppercase tracking-widest">
                    Factory to Shop • BoliBazar Technologies © 2026
                </p>
            </div>
        </div>

        <!-- Right Side: Registration Form -->
        <div class="flex-grow bg-white p-8 lg:p-16 flex flex-col justify-center items-center overflow-y-auto">
            <div class="w-full max-w-2xl">
                
                <div class="mb-10 text-center md:text-left">
                    <h3 class="text-4xl font-black mb-2 font-heading tracking-tight text-secondary">Manufacturer Registration</h3>
                    <p class="text-gray-400 text-sm font-medium">Please provide your business details. Our team will contact you within 24-48 hours.</p>
                </div>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="bg-green-50 text-green-700 p-6 rounded-2xl mb-8 flex items-center gap-4 border border-green-100 shadow-sm animate-pulse">
                        <i class="fas fa-check-circle text-2xl"></i>
                        <div>
                            <p class="font-black uppercase text-xs tracking-widest">Request Submitted Successfully!</p>
                            <p class="text-[10px] font-bold mt-1">Our partnership team will get in touch with you shortly.</p>
                        </div>
                    </div>
                    <div class="text-center">
                        <a href="/login" class="text-primary font-black uppercase text-xs tracking-widest hover:underline">Back to Login</a>
                    </div>
                <% } else { %>
                    <form action="/manufacturer-register" method="POST" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Company / Entity Name</label>
                                <input type="text" name="companyName" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="e.g. ABC Manufacturing Pvt Ltd">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Contact Person Name</label>
                                <input type="text" name="contactPerson" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="Full Name">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Official Email Address</label>
                                <input type="email" name="email" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="email@company.com">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Mobile Number</label>
                                <input type="tel" name="phone" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="+91 XXXXX XXXXX">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">GST Number (Optional)</label>
                                <input type="text" name="gstNumber" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="22AAAAA0000A1Z5">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">City</label>
                                <input type="text" name="city" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="e.g. Surat">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">State</label>
                                <input type="text" name="state" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="e.g. Gujarat">
                            </div>
                            <div>
                                <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Product Categories</label>
                                <input type="text" name="categories" required class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition" placeholder="e.g. Textiles, Electronics, Grocery">
                            </div>
                        </div>

                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase block mb-2 ml-2 tracking-widest">Brief Message / Requirements</label>
                            <textarea name="message" rows="3" class="w-full bg-gray-50 border border-gray-100 rounded-2xl px-6 py-4 text-sm font-bold focus:outline-none focus:border-primary transition resize-none" placeholder="Tell us about your production capacity or products..."></textarea>
                        </div>

                        <button type="submit" class="w-full bg-secondary text-white py-5 rounded-2xl text-[12px] font-black uppercase tracking-[0.2em] shadow-xl hover:bg-black active:scale-95 transition-all flex items-center justify-center gap-4">
                            Register As Manufacturer <i class="fas fa-industry"></i>
                        </button>
                    </form>

                    <p class="mt-8 text-center text-xs font-bold text-gray-400">
                        Already have a retailer account? <a href="/login" class="text-primary hover:underline">Sign In Instead</a>
                    </p>
                <% } %>
            </div>
        </div>

    </div>

</body>
</html>
