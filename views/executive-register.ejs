<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Executive Registration | Boli Bazar</title>
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#001f3f',
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-slate-50 font-sans min-h-screen flex items-center justify-center p-4">

    <div class="bg-white rounded-[40px] shadow-2xl overflow-hidden flex flex-col md:flex-row w-full max-w-4xl max-h-[90vh]">
        
        <!-- Left Side: Graphic -->
        <div class="bg-slate-900 w-full md:w-5/12 p-10 flex flex-col justify-between text-white relative overflow-hidden hidden md:flex">
            <div class="absolute -top-32 -left-32 w-64 h-64 bg-primary rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob"></div>
            <div class="absolute -bottom-32 -right-32 w-64 h-64 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>
            
            <div class="relative z-10">
                <a href="/" class="text-3xl font-black uppercase tracking-tighter">Boli<span class="text-primary">Bazar</span></a>
                <div class="mt-4 inline-block bg-blue-500 text-white text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded">Executive Portal</div>
            </div>

            <div class="relative z-10 my-8">
                <h2 class="text-3xl font-black mb-4">Partner with us.</h2>
                <p class="text-slate-300 text-sm font-bold leading-relaxed">Join Boli Bazar as a Sales Executive. Apna retailer network badhayein kyunki: <span class="text-white">Jitna bada network utni zyada sale, aur jitni zyada sale utni hi zyada aapki income!</span></p>
                <div class="mt-8 space-y-4">
                    <div class="flex items-center gap-3 text-sm font-bold text-slate-300">
                        <i class="fas fa-check-circle text-green-400"></i> Infinite earning potential
                    </div>
                    <div class="flex items-center gap-3 text-sm font-bold text-slate-300">
                        <i class="fas fa-check-circle text-green-400"></i> Easy dashboard tracking
                    </div>
                </div>
            </div>

            <div class="relative z-10 text-xs font-bold text-slate-500">
                &copy; <%= new Date().getFullYear() %> Boli Bazar
            </div>
        </div>

        <!-- Right Side: Form -->
        <div class="w-full md:w-7/12 p-8 md:p-12 overflow-y-auto">
            <div class="mb-8">
                <h1 class="text-3xl font-black text-slate-800 mb-2">Apply Now</h1>
                <p class="text-sm font-bold text-slate-500">Submit your application to become a Sales Executive.</p>
            </div>

            <% if (error) { %>
                <div class="bg-red-50 text-red-600 p-4 rounded-2xl mb-6 text-sm font-bold flex items-center border border-red-100">
                    <i class="fas fa-exclamation-circle mr-3 text-lg"></i> <%= error %>
                </div>
            <% } %>

            <form action="/executive-register" method="POST" enctype="multipart/form-data" class="space-y-6">
                
                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Full Name</label>
                        <input type="text" name="username" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition" placeholder="John Doe">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Mobile Number</label>
                        <input type="tel" name="phone" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition" placeholder="9876543210">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Email Address <span class="text-slate-300 font-medium">(Optional)</span></label>
                        <input type="email" name="email" class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition" placeholder="john@example.com">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Create Password</label>
                        <input type="password" name="password" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition" placeholder="••••••••">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Profile Picture</label>
                        <input type="file" name="profileImage" accept="image/*" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-3.5 text-sm font-bold focus:outline-none focus:border-blue-500 transition text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-black file:bg-blue-50 file:text-blue-600 hover:file:bg-blue-100">
                    </div>
                </div>

                <hr class="border-slate-100 my-6">

                <!-- Address Section -->
                <h3 class="text-sm font-black text-slate-800 mb-4"><i class="fas fa-map-marker-alt text-blue-500 mr-2"></i> Address Details</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Full Address</label>
                        <input type="text" name="address" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition" placeholder="123 Main Street, Area">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">City</label>
                        <input type="text" name="city" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition" placeholder="City Name">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">State</label>
                            <select name="state" id="state" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition appearance-none">
                                <option value="">Select State</option>
                                <option value="Andaman and Nicobar Islands">Andaman and Nicobar Islands</option>
                                <option value="Andhra Pradesh">Andhra Pradesh</option>
                                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                                <option value="Assam">Assam</option>
                                <option value="Bihar">Bihar</option>
                                <option value="Chandigarh">Chandigarh</option>
                                <option value="Chhattisgarh">Chhattisgarh</option>
                                <option value="Dadra and Nagar Haveli and Daman and Diu">Dadra and Nagar Haveli and Daman and Diu</option>
                                <option value="Delhi">Delhi</option>
                                <option value="Goa">Goa</option>
                                <option value="Gujarat">Gujarat</option>
                                <option value="Haryana">Haryana</option>
                                <option value="Himachal Pradesh">Himachal Pradesh</option>
                                <option value="Jammu and Kashmir">Jammu and Kashmir</option>
                                <option value="Jharkhand">Jharkhand</option>
                                <option value="Karnataka">Karnataka</option>
                                <option value="Kerala">Kerala</option>
                                <option value="Ladakh">Ladakh</option>
                                <option value="Lakshadweep">Lakshadweep</option>
                                <option value="Madhya Pradesh">Madhya Pradesh</option>
                                <option value="Maharashtra">Maharashtra</option>
                                <option value="Manipur">Manipur</option>
                                <option value="Meghalaya">Meghalaya</option>
                                <option value="Mizoram">Mizoram</option>
                                <option value="Nagaland">Nagaland</option>
                                <option value="Odisha">Odisha</option>
                                <option value="Puducherry">Puducherry</option>
                                <option value="Punjab">Punjab</option>
                                <option value="Rajasthan">Rajasthan</option>
                                <option value="Sikkim">Sikkim</option>
                                <option value="Tamil Nadu">Tamil Nadu</option>
                                <option value="Telangana">Telangana</option>
                                <option value="Tripura">Tripura</option>
                                <option value="Uttar Pradesh">Uttar Pradesh</option>
                                <option value="Uttarakhand">Uttarakhand</option>
                                <option value="West Bengal">West Bengal</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Pincode</label>
                            <input type="text" name="pincode" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-blue-500 transition" placeholder="000000">
                        </div>
                    </div>
                </div>

                <hr class="border-slate-100 my-6">

                <!-- Banking Section -->
                <h3 class="text-sm font-black text-slate-800 mb-4"><i class="fas fa-university text-green-500 mr-2"></i> Bank Details (For Commission Payouts)</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Bank Name</label>
                        <input type="text" name="bankName" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-green-500 transition" placeholder="e.g. HDFC Bank">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">Bank Account Number</label>
                        <input type="text" name="bankAccountNo" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold focus:outline-none focus:border-green-500 transition" placeholder="Account Number">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase block mb-2 ml-1 tracking-widest">IFSC Code</label>
                        <input type="text" name="ifscCode" required class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-5 py-4 text-sm font-bold uppercase focus:outline-none focus:border-green-500 transition" placeholder="IFSC Code">
                    </div>
                </div>

                <button type="submit" class="w-full bg-slate-900 text-white py-4 rounded-2xl text-sm font-black uppercase tracking-[0.2em] shadow-xl hover:bg-blue-600 transition duration-300 mt-4">
                    Submit Application <i class="fas fa-arrow-right ml-2"></i>
                </button>
                
                <p class="text-center text-xs font-bold text-slate-500 mt-6">
                    Already an executive? <a href="/login" class="text-blue-600 hover:text-blue-800 transition">Log in here</a>
                </p>
                <p class="text-center text-xs font-bold text-slate-500 mt-2">
                    Want to buy products instead? <a href="/register" class="text-primary hover:text-red-700 transition">Register as a Retailer</a>
                </p>
            </form>
        </div>
    </div>
    <script>
        const pincodeInput = document.querySelector('input[name="pincode"]');
        const cityInput = document.querySelector('input[name="city"]');
        const stateSelect = document.querySelector('select[name="state"]');

        pincodeInput.addEventListener('input', async (e) => {
            const pincode = e.target.value.replace(/\D/g, ''); // Remove non-digits
            if (pincode.length === 6) {
                pincodeInput.classList.add('opacity-50');
                try {
                    const response = await fetch(`https://api.postalpincode.in/pincode/${pincode}`);
                    const data = await response.json();
                    
                    if (data && data[0] && data[0].Status === 'Success') {
                        const postOffice = data[0].PostOffice[0];
                        cityInput.value = postOffice.District;
                        
                        // Select state in dropdown
                        let state = postOffice.State;
                        // Handle special cases for API vs Dropdown naming
                        if (state.toLowerCase().includes('delhi')) state = 'Delhi';
                        
                        let found = false;
                        for (let i = 0; i < stateSelect.options.length; i++) {
                            const optionValue = stateSelect.options[i].value.toLowerCase();
                            if (optionValue === state.toLowerCase() || state.toLowerCase().includes(optionValue)) {
                                stateSelect.selectedIndex = i;
                                found = true;
                                break;
                            }
                        }
                        if (!found) console.warn('State not found in dropdown:', state);
                    }
                } catch (error) {
                    console.error('Error fetching pincode details:', error);
                } finally {
                    pincodeInput.classList.remove('opacity-50');
                }
            }
        });
    </script>
</body>
</html>
