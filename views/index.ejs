<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BoliBazar | Leaderboard</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css?v=<%= typeof v !== 'undefined' ? v : '1.0' %>">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#001f3f',
                        'leader-pink': '#ff006e',
                        'leader-purple': '#a000ff',
                        'bronze': '#cd7f32',
                        'silver': '#c0c0c0',
                        'gold': '#ffd700'
                    }
                }
            }
        }
    </script>
    
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #0c0d19; color: white; }
        .header-gradient { background: linear-gradient(to right, #ff006e, #a000ff); }
        .podium-gradient { background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0) 100%); }
        .card-gold { border: 1px solid rgba(255, 215, 0, 0.2); background: rgba(255, 215, 0, 0.03); }
        .card-silver { border: 1px solid rgba(192, 192, 192, 0.2); background: rgba(192, 192, 192, 0.03); }
        .card-bronze { border: 1px solid rgba(205, 127, 50, 0.2); background: rgba(205, 127, 50, 0.03); }
        .info-bar { border: 1px solid rgba(255, 193, 7, 0.15); background: rgba(255, 193, 7, 0.04); }
        .glow-gold { filter: drop-shadow(0 0 15px rgba(255, 195, 0, 0.4)); }
        
        /* Swiper Customization: Full Width Hero */
        .hero-swiper { width: 100%; height: 500px; overflow: hidden; margin-bottom: 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .swiper-slide { position: relative; width: 100%; }
        .swiper-slide img { width: 100%; height: 100%; object-fit: cover; }
        .swiper-pagination-bullet { background: #fff !important; }
        .swiper-pagination-bullet-active { background: #d90429 !important; }

        /* Live Bidding Strip: Clearly Separated Design */
        .live-strip-container { 
            background: #1a1b2e; 
            border-top: 1px solid rgba(255,255,255,0.05);
            border-bottom: 2px solid #d90429; 
            position: relative; 
            z-index: 40; 
            padding: 25px 0;
            box-shadow: inset 0 0 50px rgba(0,0,0,0.5);
        }
        .bidding-card { 
            background: rgba(255, 255, 255, 0.04); 
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1); 
            border-radius: 1.5rem;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .bidding-card:hover { 
            background: rgba(255, 255, 255, 0.08); 
            transform: translateY(-8px);
            border-color: #d90429;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 20px rgba(217, 4, 41, 0.2);
        }
        .price-glow { 
            color: #fff; 
            text-shadow: 0 0 20px rgba(217, 4, 41, 0.6); 
            font-family: 'Outfit', sans-serif;
        }
        .timer-glow {
            color: #fff;
            text-shadow: 0 0 20px rgba(255,255,255,0.5);
        }
    </style>
</head>
<body class="antialiased min-h-screen">

    <!-- Top Nav -->
    <header class="bg-[#0c0d19] border-b border-white/5 py-3 px-6 sticky top-0 z-[100] backdrop-blur-lg">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="flex items-center space-x-2">
                <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center text-white">
                    <i class="fas fa-gavel text-lg"></i>
                </div>
                <span class="text-xl font-black uppercase tracking-tighter italic">Boli<span class="text-primary">Bazar</span></span>
            </a>
            <div class="flex items-center space-x-6">
                <nav class="hidden sm:flex space-x-6 text-[10px] font-black uppercase tracking-widest text-gray-500">
                    <a href="/" class="text-white">Leaderboard</a>
                    <a href="/auctions" class="hover:text-white transition">Live Auctions</a>
                </nav>
                <div>
                    <% if (user) { %>
                        <a href="/dashboard" class="group flex items-center space-x-3 bg-white/5 border border-white/10 px-5 py-2.5 rounded-full hover:bg-primary transition shadow-xl relative z-[1001]">
                            <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-[10px] group-hover:bg-white/20">
                                <i class="fas fa-user text-white"></i>
                            </div>
                            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white">Dashboard</span>
                        </a>
                    <% } else { %>
                        <a href="/login" class="text-[10px] font-black uppercase tracking-widest py-2 hover:text-primary transition mr-4">Login</a>
                        <a href="/register" class="bg-primary hover:bg-red-700 px-6 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition shadow-lg shadow-red-500/20">Join</a>
                    <% } %>
                </div>
            </div>
        </div>
    </header>

    <!-- DEBUG_TRACER: FILE_IN_PRIMARY_VIEWS_FOLDER -->

    <!-- Live Bidding Strip: Top 5 Highlights (Creative Redesign) -->
    <div class="live-strip-container">
        <div class="container mx-auto px-6">
            <div class="swiper live-bidding-swiper">
                <div class="swiper-wrapper">
                    <% if (typeof liveProducts !== 'undefined' && liveProducts.length > 0) { %>
                        <% liveProducts.forEach(product => { %>
                            <div class="swiper-slide">
                                <a href="/auctions" class="bidding-card group relative p-4 rounded-3xl overflow-hidden shadow-2xl border border-white/5 transition-all duration-500 hover:border-primary/50">
                                    <!-- Animated Background Glow -->
                                    <div class="absolute -top-10 -left-10 w-24 h-24 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-all duration-700"></div>
                                    
                                    <div class="relative flex items-center space-x-5 z-10 w-full">
                                        <!-- Image with 3D Effect on Hover -->
                                        <div class="w-16 h-16 rounded-2xl overflow-hidden border-2 border-white/10 group-hover:border-primary/40 transition-all duration-500 shadow-lg shrink-0">
                                            <img src="<%= product.imageUrl || '/lot1.png' %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-125">
                                        </div>

                                        <div class="min-w-0 flex-grow relative flex items-center justify-between">
                                             <div class="flex flex-col space-y-2">
                                                 <div class="flex items-center gap-2">
                                                     <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></div>
                                                     <h4 class="text-[10px] font-black uppercase text-gray-300 tracking-[0.2em] truncate group-hover:text-primary transition-colors"><%= product.title %></h4>
                                                 </div>
                                                 <div class="flex flex-col">
                                                     <span class="text-[8px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Price</span>
                                                     <span class="text-xl font-black text-white italic tracking-tighter price-glow">₹<%= (product.currentBid || product.initialPrice || 0).toLocaleString() %></span>
                                                 </div>
                                             </div>

                                             <!-- Large Center Timer (Bright & Glowing) -->
                                             <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center pointer-events-none">
                                                 <span class="text-[7px] font-black text-white/70 uppercase tracking-[0.4em] mb-1">Ends In</span>
                                                 <span class="text-2xl font-black font-mono text-white countdown-timer tracking-tight timer-glow" data-endtime="<%= product.endTime %>">00:00:00</span>
                                             </div>
                                             
                                             <div class="flex flex-col items-end space-y-3">
                                                 <div class="bg-gradient-to-r from-primary to-rose-600 px-5 py-2 rounded-full shadow-lg shadow-red-500/20 group-hover:shadow-red-500/40 transition-all duration-500 border border-white/10 group-hover:scale-105 active:scale-95 cursor-pointer">
                                                     <span class="text-[10px] font-black text-white uppercase tracking-tighter">BID NOW</span>
                                                 </div>
                                                 <div class="flex flex-col items-end">
                                                     <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest">Lot Size</p>
                                                     <p class="text-sm text-white font-black tracking-tighter"><%= product.lotSize %></p>
                                                 </div>
                                             </div>
                                         </div>
                                    </div>
                                </a>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="swiper-slide">
                            <div class="p-6 text-center rounded-3xl bg-white/5 border border-dashed border-white/10">
                                <span class="text-[10px] uppercase font-black text-gray-500 tracking-[0.3em]">
                                    <i class="fas fa-radar text-primary mr-2 animate-spin-slow"></i> Scanning for Live Lots...
                                </span>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Full Width Hero Slider -->
    <% if (typeof banners !== 'undefined' && banners.length > 0) { %>
        <div class="w-full relative overflow-hidden mb-8">
            <div class="swiper hero-swiper">
                <div class="swiper-wrapper">
                    <% banners.forEach(banner => { %>
                        <div class="swiper-slide !h-[450px]">
                            <img src="<%= banner.imageUrl %>" class="w-full h-full object-cover" alt="<%= banner.title %>">
                            <% if (banner.title) { %>
                                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex items-end p-10 sm:p-20">
                                    <h2 class="text-4xl sm:text-6xl font-black uppercase tracking-tight max-w-4xl"><%= banner.title %></h2>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
                <!-- Premium Navigation Controls -->
                <div class="swiper-pagination"></div>
                <div class="swiper-button-next !text-white !w-12 !h-12 after:!text-sm bg-black/40 rounded-full flex items-center justify-center border border-white/20 backdrop-blur-md hover:bg-primary transition-all duration-300"></div>
                <div class="swiper-button-prev !text-white !w-12 !h-12 after:!text-sm bg-black/40 rounded-full flex items-center justify-center border border-white/20 backdrop-blur-md hover:bg-primary transition-all duration-300"></div>
            </div>
        </div>
    <% } %>

    <main class="container mx-auto px-4 py-8 max-w-5xl">

        <!-- Outer Wrapper to match Screenshot Container -->
        <div class="bg-[#111222] rounded-[3rem] border border-white/5 shadow-2x overflow-hidden pb-12">
            
            <!-- Leaderboard Header (Vibrant Gradient) -->
            <div class="header-gradient p-10 flex justify-between items-center relative">
                <div class="flex items-center space-x-6 relative z-10">
                    <div class="w-16 h-16 bg-white/10 rounded-3xl flex items-center justify-center border border-white/20">
                        <i class="fas fa-trophy text-4xl text-white/90"></i>
                    </div>
                    <div>
                        <h1 class="text-3xl font-black tracking-tight leading-tight">This Month's Leaderboard</h1>
                        <p class="text-[11px] font-black text-white/60 uppercase tracking-[0.2em] mt-1.5">April 2026 • 1 Spend = 1 Coin <i class="fas fa-coins text-yellow-500 ml-0.5"></i></p>
                    </div>
                </div>
                <div class="bg-black/20 text-white px-5 py-2.5 rounded-full border border-white/20 flex items-center space-x-2 relative z-10">
                    <span class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse shadow-[0_0_12px_#22c55e]"></span>
                    <span class="text-[10px] font-black uppercase tracking-[0.3em]">Live</span>
                </div>
            </div>

            <div class="p-8 md:p-12">
                <!-- Rewards Section -->
                <div class="flex items-center space-x-3 mb-8">
                    <i class="fas fa-calendar-alt text-[#ffc107] text-lg"></i>
                    <h2 class="text-xs font-black uppercase tracking-[0.3em] text-[#ffc107]">Monthly Rewards Scheme — Top 3 ko Milega</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-16">
                    <% rewards.forEach(reward => { 
                        let cardClass = reward.rank === 1 ? 'card-gold' : (reward.rank === 2 ? 'card-silver' : 'card-bronze');
                        let iconClass = reward.rank === 1 ? 'fas fa-crown text-gold' : (reward.rank === 2 ? 'fas fa-medal text-blue-400' : 'fas fa-award text-orange-400');
                        let textClass = reward.rank === 1 ? 'text-gold/70' : (reward.rank === 2 ? 'text-blue-400/70' : 'text-orange-400/70');
                    %>
                    <div class="<%= cardClass %> p-6 rounded-3xl group hover:bg-white/5 transition-all flex flex-col">
                        <div class="flex items-center space-x-3 mb-4">
                            <i class="<%= iconClass %> text-sm"></i>
                            <span class="text-[10px] font-black uppercase tracking-widest <%= textClass %>">
                                <%= reward.rank === 1 ? '1st Place' : (reward.rank === 2 ? '2nd Place' : '3rd Place') %>
                            </span>
                        </div>
                        
                        <% if (reward.imageUrl) { %>
                            <div class="w-full h-32 rounded-2xl overflow-hidden mb-4 border border-white/5 bg-white/5">
                                <img src="<%= reward.imageUrl %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                            </div>
                        <% } %>

                        <h3 class="text-lg font-black leading-tight mb-2"><%= reward.title %></h3>
                        <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest mt-auto"><%= reward.description %></p>
                    </div>
                    <% }); %>
                </div>

                <p class="text-center text-[10px] text-gray-500 font-bold italic mb-6">🏆 Jitna zyada kharido, utne zyada coins — month end pe top 3 ko rewards milenge!</p>

                <!-- Podium Section (Dynamic) -->
                <div class="flex items-end justify-center space-x-3 md:space-x-10 mb-20 min-h-[300px]">
                    
                    <% if (leaderboard && leaderboard.length >= 2) { 
                        const runnerUp = leaderboard[1];
                        const initials = runnerUp.username.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
                    %>
                    <!-- #2 Runner Up -->
                    <div class="flex flex-col items-center">
                        <div class="w-16 h-16 bg-[#6366f1] rounded-full flex items-center justify-center text-xl font-black border-4 border-[#161729] shadow-2xl z-20 translate-y-4">
                            <%= initials %>
                        </div>
                        <div class="bg-gradient-to-b from-[#1c1e30] to-transparent border border-white/5 p-6 pt-10 rounded-2xl w-32 md:w-52 text-center">
                            <i class="fas fa-medal text-silver mb-2 block"></i>
                            <h4 class="text-xs font-black truncate"><%= runnerUp.username %></h4>
                            <p class="text-[9px] text-gray-500 uppercase tracking-widest font-bold mb-3 truncate"><%= runnerUp.city || 'Retailer' %></p>
                            <p class="text-sm font-black text-silver/80 flex items-center justify-center space-x-1">
                                <i class="fas fa-coins text-[10px]"></i>
                                <span><%= (runnerUp.monthlyCoins || 0).toLocaleString() %></span>
                            </p>
                        </div>
                    </div>
                    <% } %>

                    <% if (leaderboard && leaderboard.length >= 1) { 
                        const winner = leaderboard[0];
                        const initials = winner.username.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
                    %>
                    <!-- #1 Winner -->
                    <div class="flex flex-col items-center -translate-y-6">
                        <div class="relative z-30 translate-y-6">
                             <div class="w-20 h-20 md:w-24 md:h-24 bg-[#ffc107] rounded-full flex items-center justify-center text-2xl font-black border-4 border-[#1b1c2e] glow-gold">
                                <%= initials %>
                             </div>
                             <div class="absolute -top-3 -right-2 bg-yellow-400 text-gray-900 w-9 h-9 rounded-full flex items-center justify-center border-4 border-[#222336] shadow-lg">
                                <i class="fas fa-crown text-[10px]"></i>
                             </div>
                        </div>
                        <div class="bg-gradient-to-b from-[#2a2d3d] to-transparent border border-white/10 p-8 pt-10 rounded-3xl w-40 md:w-64 text-center">
                            <i class="fas fa-trophy text-gold mb-3 block"></i>
                            <h4 class="text-sm font-black text-gold truncate"><%= winner.username %></h4>
                            <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold mb-4 truncate"><%= winner.city || 'India' %></p>
                            <p class="text-xl font-black text-white flex items-center justify-center space-x-2">
                                <i class="fas fa-coins text-gold"></i>
                                <span><%= (winner.monthlyCoins || 0).toLocaleString() %></span>
                            </p>
                        </div>
                    </div>
                    <% } %>

                    <% if (leaderboard && leaderboard.length >= 3) { 
                        const third = leaderboard[2];
                        const initials = third.username.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
                    %>
                    <!-- #3 Third Place -->
                    <div class="flex flex-col items-center">
                        <div class="w-16 h-16 bg-[#f43f5e] rounded-full flex items-center justify-center text-xl font-black border-4 border-[#161729] shadow-2xl z-20 translate-y-4">
                            <%= initials %>
                        </div>
                        <div class="bg-gradient-to-b from-[#1c1e30] to-transparent border border-white/5 p-6 pt-10 rounded-2xl w-32 md:w-52 text-center">
                            <i class="fas fa-medal text-orange-500 mb-2 block"></i>
                            <h4 class="text-xs font-black truncate"><%= third.username %></h4>
                            <p class="text-[9px] text-gray-500 uppercase tracking-widest font-bold mb-3 truncate"><%= third.city || 'Retailer' %></p>
                            <p class="text-sm font-black text-orange-500/80 flex items-center justify-center space-x-1">
                                <i class="fas fa-coins text-[10px]"></i>
                                <span><%= (third.monthlyCoins || 0).toLocaleString() %></span>
                            </p>
                        </div>
                    </div>
                    <% } %>

                    <% if (!leaderboard || leaderboard.length === 0) { %>
                        <div class="text-center py-10 opacity-50">
                            <i class="fas fa-users text-4xl mb-4 block"></i>
                            <p class="text-xs font-black uppercase tracking-widest">No rankings yet this month</p>
                        </div>
                    <% } %>

                </div>

                <!-- Footer Table List (Dynamic Ranks 4+) -->
                <div class="space-y-4 mb-16">
                    <% if (leaderboard && leaderboard.length > 3) { %>
                        <% leaderboard.slice(3).forEach((retailer, index) => { 
                            const initials = retailer.username.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2);
                        %>
                        <div class="bg-white/5 border border-white/5 p-6 rounded-[2rem] flex items-center justify-between hover:bg-white/10 transition px-10">
                            <div class="flex items-center space-x-6">
                                <div class="w-10 h-10 bg-gradient-to-br from-leader-pink to-leader-purple rounded-full flex items-center justify-center text-[10px] font-black italic">#<%= index + 4 %></div>
                                <div class="w-11 h-11 bg-brand-pink bg-[#ff3d71] rounded-full flex items-center justify-center font-black text-xs uppercase"><%= initials %></div>
                                <div>
                                    <h4 class="text-sm font-black"><%= retailer.username %></h4>
                                    <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest mt-0.5"><%= retailer.city || 'Retailer' %></p>
                                </div>
                            </div>
                            <div class="text-right">
                                 <p class="text-base font-black flex items-center justify-end">
                                     <i class="fas fa-coins text-[10px] text-gray-500 mr-2"></i>
                                     <%= (retailer.monthlyCoins || 0).toLocaleString() %>
                                 </p>
                            </div>
                        </div>
                        <% }); %>
                    <% } %>
                </div>

                <!-- Bottom Info Bar -->
                <div class="info-bar p-7 rounded-[2.5rem] flex items-center space-x-8">
                    <div class="w-16 h-16 bg-[#ffc300] text-gray-900 rounded-full flex items-center justify-center text-3xl shadow-lg border-4 border-[#222336] shrink-0">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <div>
                        <h5 class="text-sm font-black uppercase tracking-[0.2em] text-yellow-500 mb-1">Coin System — Har Rupee Counts!</h5>
                        <p class="text-[10px] text-yellow-500/60 font-bold leading-relaxed">Jitna kharido utne coins milenge. 1 Spend = 1 Coin • Coins ke hissab se rank upar-neeche hota hai</p>
                    </div>
                </div>

            </div>
        </div>

        <!-- KING-SIZE Hall of Fame: LAST MONTH WINNERS (Relocated to Bottom) -->
        <% if (typeof lastMonthWinners !== 'undefined' && lastMonthWinners.length > 0) { %>
        <div class="mt-16 mb-20 bg-[#161729] rounded-[3rem] p-10 border border-white/10 shadow-2xl relative overflow-hidden">
             <!-- Cyber Decorative Elements -->
             <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 blur-[100px] -z-10"></div>
             <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-500/10 blur-[100px] -z-10"></div>

             <div class="flex flex-col items-center text-center mb-12">
                <div class="w-20 h-20 bg-gradient-to-br from-yellow-400 to-amber-600 rounded-3xl flex items-center justify-center shadow-lg shadow-yellow-500/20 mb-6 border border-white/20">
                    <i class="fas fa-history text-3xl text-white"></i>
                </div>
                <h2 class="text-3xl font-black uppercase tracking-[0.2em] text-white">Hall of Fame</h2>
                <p class="text-xs font-bold text-gray-500 uppercase tracking-[0.4em] mt-2">Last Month's Legendary Champions</p>
             </div>

             <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <% lastMonthWinners.forEach(winner => { 
                    let rankColor = winner.rank === 1 ? 'text-yellow-400 shadow-yellow-500/20' : (winner.rank === 2 ? 'text-slate-300 shadow-slate-300/20' : 'text-amber-600 shadow-amber-600/20');
                    let rankBg = winner.rank === 1 ? 'bg-yellow-400/10' : (winner.rank === 2 ? 'bg-slate-300/10' : 'bg-amber-600/10');
                    let cardBorder = winner.rank === 1 ? 'border-yellow-400/20' : (winner.rank === 2 ? 'border-white/10' : 'border-white/10');
                %>
                <div class="bg-black/40 border <%= cardBorder %> p-8 rounded-[2.5rem] flex flex-col items-center text-center relative overflow-hidden group hover:bg-white/5 transition-all duration-500">
                    <!-- Dynamic Large Rank Number -->
                    <span class="absolute -left-4 -top-6 text-[120px] font-black italic text-white/5 pointer-events-none group-hover:text-white/10 transition-all uppercase"><%= winner.rank %></span>
                    
                    <div class="relative mb-6">
                        <div class="w-24 h-24 rounded-[2rem] overflow-hidden border-4 border-white/10 shadow-2xl relative z-10">
                            <img src="<%= winner.profileImage || '/lot1.png' %>" class="w-full h-full object-cover">
                        </div>
                        <div class="absolute -bottom-3 -right-3 w-10 h-10 <%= rankBg %> text-white rounded-full flex items-center justify-center border-4 border-[#161729] z-20 <%= rankColor %>">
                            <i class="fas <%= winner.rank === 1 ? 'fa-crown' : 'fa-medal' %> text-sm"></i>
                        </div>
                    </div>

                    <p class="text-[11px] font-black uppercase tracking-[0.3em] <%= rankColor %> mb-2">Rank #<%= winner.rank %></p>
                    <h4 class="text-xl font-black text-white mb-4 group-hover:text-primary transition-colors"><%= winner.shopName || winner.username %></h4>
                    
                    <div class="flex items-center space-x-3 bg-white/5 px-6 py-2.5 rounded-full border border-white/10">
                        <i class="fas fa-phone text-xs text-primary"></i>
                        <span class="text-xs font-black tracking-widest text-white/80"><%= winner.mobileNumber %></span>
                    </div>

                    <div class="mt-6 pt-6 border-t border-white/5 w-full">
                        <p class="text-[9px] font-black text-gray-500 uppercase tracking-widest">Score Achieved</p>
                        <p class="text-lg font-black text-white/90">
                            <i class="fas fa-coins text-yellow-500 mr-2"></i>
                            <%= (winner.coins || 0).toLocaleString() %>
                        </p>
                    </div>
                </div>
                <% }); %>
             </div>
        </div>
        <% } %>
    </main>

    <footer class="py-12 border-t border-white/5 text-center mt-10 opacity-30">
        <p class="text-[9px] font-black uppercase tracking-[0.5em]">© 2026 BOLIBAZAR TECHNOLOGIES PVT LTD</p>
    </footer>

    <!-- High-Contrast Dynamic Global Alert (Bottom Right) -->
    <div id="live-notification" class="fixed bottom-8 right-8 z-[200] hidden">
        <div class="bg-gradient-to-br from-primary via-[#ff3d71] to-rose-700 p-4 rounded-2xl shadow-[0_20px_50px_rgba(217,4,41,0.3)] flex items-center space-x-4 max-w-sm border border-white/20 animate-pulse-subtle overflow-hidden">
             <div class="w-10 h-10 bg-white/10 text-[#e2e8f0] rounded-xl flex items-center justify-center text-lg shrink-0 shadow-inner">
                 <i class="fas fa-bolt"></i>
             </div>
             <div>
                <p class="text-[9px] font-black text-[#e2e8f0]/60 mb-0.5 uppercase tracking-[0.2em]">Live Bidding War</p>
                <p id="notif-text" class="text-[11px] font-black text-[#e2e8f0] leading-tight">
                    <!-- Dynamic content will be injected here -->
                </p>
             </div>
        </div>
    </div>

    <style>
        .animate-pulse-subtle {
            animation: pulse-border 3s infinite;
        }
        @keyframes pulse-border {
            0%, 100% { box-shadow: 0 20px 50px rgba(217,4,41,0.3); }
            50% { box-shadow: 0 20px 60px rgba(217,4,41,0.6); }
        }
        @keyframes slide-in {
            from { transform: translateX(120%) scale(0.9); opacity: 0; }
            to { transform: translateX(0) scale(1); opacity: 1; }
        }
        @keyframes slide-out {
            from { transform: translateX(0) scale(1); opacity: 1; }
            to { transform: translateX(120%) scale(0.9); opacity: 0; }
        }
        .notif-enter { animation: slide-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
        .notif-exit { animation: slide-out 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // HERO SLIDER INIT
            const heroSwiper = new Swiper('.hero-swiper', {
                loop: true,
                autoplay: { delay: 5000, disableOnInteraction: false },
                pagination: { el: '.swiper-pagination', clickable: true },
                navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
                effect: 'fade',
                fadeEffect: { crossFade: true }
            });

            // LIVE BIDDING STRIP INIT
            if (document.querySelector('.live-bidding-swiper')) {
                const liveSwiper = new Swiper('.live-bidding-swiper', {
                    slidesPerView: 1,
                    spaceBetween: 20,
                    loop: true,
                    autoplay: { delay: 3000, disableOnInteraction: false },
                    breakpoints: {
                        640: { slidesPerView: 2 },
                        1024: { slidesPerView: 3 }
                    }
                });
            }

            // --- COUNTDOWN TIMER LOGIC ---
            function updateCountdowns() {
                document.querySelectorAll('.countdown-timer').forEach(el => {
                    const endTime = new Date(el.dataset.endtime).getTime();
                    const now = new Date().getTime();
                    const distance = endTime - now;

                    if (distance < 0) {
                        el.innerHTML = "CLOSED";
                        el.classList.add('text-gray-500');
                        el.classList.remove('text-primary');
                        return;
                    }

                    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                    el.innerHTML = 
                        (hours < 10 ? '0' + hours : hours) + ":" + 
                        (minutes < 10 ? '0' + minutes : minutes) + ":" + 
                        (seconds < 10 ? '0' + seconds : seconds);
                });
            }
            setInterval(updateCountdowns, 1000);
            updateCountdowns(); 

            // --- DYNAMIC NOTIFICATION ROTATION ---
            const liveProducts = <%- JSON.stringify(liveProducts || []) %>;
            const notifContainer = document.getElementById('live-notification');
            const notifText = document.getElementById('notif-text');
            let currentNotifIndex = 0;

            if (liveProducts.length > 0) {
                function showNextNotification() {
                    const product = liveProducts[currentNotifIndex];
                    
                    // Prepare content
                    const emojis = ['🔥', '⚡', '🚀', '💎'];
                    const randomEmoji = emojis[Math.floor(Math.random() * emojis.length)];
                    const price = (product.currentBid || product.initialPrice || 0).toLocaleString();
                    
                    notifText.innerHTML = `${randomEmoji} <span class="text-[#e2e8f0] font-black">${product.title}</span> — price <span class="text-[#e2e8f0] font-black tracking-tighter">₹${price}</span> ho gaya!`;
                    
                    // Show animation
                    notifContainer.classList.remove('hidden', 'notif-exit');
                    notifContainer.classList.add('notif-enter');
                    
                    // Auto-hide after some time
                    setTimeout(() => {
                        notifContainer.classList.remove('notif-enter');
                        notifContainer.classList.add('notif-exit');
                        
                        setTimeout(() => {
                            currentNotifIndex = (currentNotifIndex + 1) % liveProducts.length;
                            showNextNotification();
                        }, 1000); // Wait for exit animation to finish
                    }, 5000); // Stay visible for 5s
                }

                // Start rotation with a small delay
                setTimeout(showNextNotification, 3000);
            }
        });
    </script>
</body>
</html>
