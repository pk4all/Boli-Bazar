<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BoliBazar | Leaderboard</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css?v=<%= typeof v !== 'undefined' ? v : '1.0' %>">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#d90429',
                        secondary: '#001f3f',
                        'leader-pink': '#ff006e',
                        'leader-purple': '#a000ff',
                        'bronze': '#cd7f32',
                        'silver': '#c0c0c0',
                        'gold': '#ffd700'
                    }
                }
            }
        }
    </script>
    
    <style>
        body { font-family: 'Outfit', sans-serif; background-color: #0c0d19; color: white; }
        .header-gradient { background: linear-gradient(to right, #ff006e, #a000ff); }
        .podium-gradient { background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0) 100%); }
        .card-gold { border: 1px solid rgba(255, 215, 0, 0.2); background: rgba(255, 215, 0, 0.03); }
        .card-silver { border: 1px solid rgba(192, 192, 192, 0.2); background: rgba(192, 192, 192, 0.03); }
        .card-bronze { border: 1px solid rgba(205, 127, 50, 0.2); background: rgba(205, 127, 50, 0.03); }
        .info-bar { border: 1px solid rgba(255, 193, 7, 0.15); background: rgba(255, 193, 7, 0.04); }
        .glow-gold { filter: drop-shadow(0 0 15px rgba(255, 195, 0, 0.4)); }
    </style>
</head>
<body class="antialiased min-h-screen">

    <!-- Top Nav -->
    <header class="bg-[#0c0d19] border-b border-white/5 py-3 px-6 sticky top-0 z-[100] backdrop-blur-lg">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" class="flex items-center space-x-2">
                <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center text-white">
                    <i class="fas fa-gavel text-lg"></i>
                </div>
                <span class="text-xl font-black uppercase tracking-tighter italic">Boli<span class="text-primary">Bazar</span></span>
            </a>
            <div class="flex items-center space-x-6">
                <nav class="hidden sm:flex space-x-6 text-[10px] font-black uppercase tracking-widest text-gray-500">
                    <a href="/" class="text-white">Leaderboard</a>
                    <a href="/auctions" class="hover:text-white transition">Live Auctions</a>
                </nav>
                <div>
                    <% if (user) { %>
                        <a href="/dashboard" class="text-[10px] font-black uppercase tracking-widest bg-white/5 px-4 py-2 rounded-full border border-white/10 flex items-center space-x-2">
                            <i class="fas fa-user-circle"></i>
                            <span>My Account</span>
                        </a>
                    <% } else { %>
                        <a href="/login" class="text-[10px] font-black uppercase tracking-widest py-2 hover:text-primary transition mr-4">Login</a>
                        <a href="/register" class="bg-primary hover:bg-red-700 px-6 py-2.5 rounded-full text-[10px] font-black uppercase tracking-widest transition shadow-lg shadow-red-500/20">Join</a>
                    <% } %>
                </div>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8 max-w-5xl">

        <!-- Outer Wrapper to match Screenshot Container -->
        <div class="bg-[#111222] rounded-[3rem] border border-white/5 shadow-2x overflow-hidden pb-12">
            
            <!-- Leaderboard Header (Vibrant Gradient) -->
            <div class="header-gradient p-10 flex justify-between items-center relative">
                <div class="flex items-center space-x-6 relative z-10">
                    <div class="w-16 h-16 bg-white/10 rounded-3xl flex items-center justify-center border border-white/20">
                        <i class="fas fa-trophy text-4xl text-white/90"></i>
                    </div>
                    <div>
                        <h1 class="text-3xl font-black tracking-tight leading-tight">This Month's Leaderboard</h1>
                        <p class="text-[11px] font-black text-white/60 uppercase tracking-[0.2em] mt-1.5">April 2026 • ₹1 Spend = 1 Coin <i class="fas fa-coins ml-0.5"></i></p>
                    </div>
                </div>
                <div class="bg-black/20 text-white px-5 py-2.5 rounded-full border border-white/20 flex items-center space-x-2 relative z-10">
                    <span class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse shadow-[0_0_12px_#22c55e]"></span>
                    <span class="text-[10px] font-black uppercase tracking-[0.3em]">Live</span>
                </div>
            </div>

            <div class="p-8 md:p-12">
                <!-- Rewards Section -->
                <div class="flex items-center space-x-3 mb-8">
                    <i class="fas fa-calendar-alt text-[#ffc107] text-lg"></i>
                    <h2 class="text-xs font-black uppercase tracking-[0.3em] text-[#ffc107]">Monthly Rewards Scheme — Top 3 ko Milega</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-16">
                    <!-- 1st Reward -->
                    <div class="card-gold p-6 rounded-3xl group hover:bg-gold/5 transition-all">
                        <div class="flex items-center space-x-3 mb-4">
                            <i class="fas fa-crown text-gold text-sm"></i>
                            <span class="text-[10px] font-black uppercase tracking-widest text-gold/70">1st Place</span>
                        </div>
                        <h3 class="text-lg font-black leading-tight mb-2">FREE Delivery for 1 Month</h3>
                        <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">• Exclusive Gold Badge • 5% Extra Discount</p>
                    </div>
                    <!-- 2nd Reward -->
                    <div class="card-silver p-6 rounded-3xl group hover:bg-silver/5 transition-all">
                        <div class="flex items-center space-x-3 mb-4 text-blue-400">
                            <i class="fas fa-medal text-sm"></i>
                            <span class="text-[10px] font-black uppercase tracking-widest opacity-70">2nd Place</span>
                        </div>
                        <h3 class="text-lg font-black leading-tight mb-2">3% Extra Discount on All Orders</h3>
                        <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">• Silver Badge • Priority Support</p>
                    </div>
                    <!-- 3rd Reward -->
                    <div class="card-bronze p-6 rounded-3xl group hover:bg-bronze/5 transition-all">
                        <div class="flex items-center space-x-3 mb-4 text-orange-400">
                            <i class="fas fa-award text-sm"></i>
                            <span class="text-[10px] font-black uppercase tracking-widest opacity-70">3rd Place</span>
                        </div>
                        <h3 class="text-lg font-black leading-tight mb-2">₹500 Cashback Voucher</h3>
                        <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">• Bronze Badge • Early Access to New Lots</p>
                    </div>
                </div>

                <p class="text-center text-[10px] text-gray-500 font-bold italic mb-6">🏆 Jitna zyada kharido, utne zyada coins — month end pe top 3 ko rewards milenge!</p>

                <!-- Podium Section (Fixed Overlaps) -->
                <div class="flex items-end justify-center space-x-3 md:space-x-10 mb-20">
                    
                    <!-- #2 Suresh Agarwal (Kanpur) -->
                    <div class="flex flex-col items-center">
                        <div class="w-16 h-16 bg-[#6366f1] rounded-full flex items-center justify-center text-xl font-black border-4 border-[#161729] shadow-2xl z-20 translate-y-4">SA</div>
                        <div class="bg-gradient-to-b from-[#1c1e30] to-transparent border border-white/5 p-6 pt-10 rounded-2xl w-32 md:w-52 text-center">
                            <i class="fas fa-medal text-silver mb-2 block"></i>
                            <h4 class="text-xs font-black">Suresh Agarwal</h4>
                            <p class="text-[9px] text-gray-500 uppercase tracking-widest font-bold mb-3">Kanpur</p>
                            <p class="text-sm font-black text-silver/80 flex items-center justify-center space-x-1">
                                <i class="fas fa-coins text-[10px]"></i>
                                <span>2,15,302</span>
                            </p>
                        </div>
                    </div>

                    <!-- #1 Priya Sharma (Jaipur) -->
                    <div class="flex flex-col items-center -translate-y-6">
                        <div class="relative z-30 translate-y-6">
                             <div class="w-20 h-20 md:w-24 md:h-24 bg-[#ffc107] rounded-full flex items-center justify-center text-2xl font-black border-4 border-[#1b1c2e] glow-gold">PS</div>
                             <div class="absolute -top-3 -right-2 bg-yellow-400 text-gray-900 w-9 h-9 rounded-full flex items-center justify-center border-4 border-[#222336] shadow-lg">
                                <i class="fas fa-crown text-[10px]"></i>
                             </div>
                        </div>
                        <div class="bg-gradient-to-b from-[#2a2d3d] to-transparent border border-white/10 p-8 pt-10 rounded-3xl w-40 md:w-64 text-center">
                            <i class="fas fa-trophy text-gold mb-3 block"></i>
                            <h4 class="text-sm font-black text-gold">Priya Sharma</h4>
                            <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold mb-4">Jaipur</p>
                            <p class="text-xl font-black text-white flex items-center justify-center space-x-2">
                                <i class="fas fa-coins text-gold"></i>
                                <span>2,20,920</span>
                            </p>
                        </div>
                    </div>

                    <!-- #3 Kavita Patel (Surat) -->
                    <div class="flex flex-col items-center">
                        <div class="w-16 h-16 bg-[#f43f5e] rounded-full flex items-center justify-center text-xl font-black border-4 border-[#161729] shadow-2xl z-20 translate-y-4">KP</div>
                        <div class="bg-gradient-to-b from-[#1c1e30] to-transparent border border-white/5 p-6 pt-10 rounded-2xl w-32 md:w-52 text-center">
                            <i class="fas fa-medal text-orange-500 mb-2 block"></i>
                            <h4 class="text-xs font-black">Kavita Patel</h4>
                            <p class="text-[9px] text-gray-500 uppercase tracking-widest font-bold mb-3">Surat</p>
                            <p class="text-sm font-black text-orange-500/80 flex items-center justify-center space-x-1">
                                <i class="fas fa-coins text-[10px]"></i>
                                <span>2,00,873</span>
                            </p>
                        </div>
                    </div>

                </div>

                <!-- Footer Table List (Remaining ranks) -->
                <div class="space-y-4 mb-16">
                    <!-- Rank 4 -->
                    <div class="bg-white/5 border border-white/5 p-6 rounded-[2rem] flex items-center justify-between hover:bg-white/10 transition px-10">
                        <div class="flex items-center space-x-6">
                            <div class="w-10 h-10 bg-gradient-to-br from-leader-pink to-leader-purple rounded-full flex items-center justify-center text-[10px] font-black italic">#4</div>
                            <div class="w-11 h-11 bg-brand-pink bg-[#ff3d71] rounded-full flex items-center justify-center font-black text-xs">MI</div>
                            <div>
                                <h4 class="text-sm font-black">Mohammed Iqbal</h4>
                                <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest mt-0.5">Lucknow</p>
                            </div>
                        </div>
                        <div class="text-right">
                             <p class="text-base font-black flex items-center justify-end">
                                 <i class="fas fa-coins text-[10px] text-gray-500 mr-2"></i>
                                 1,86,825
                             </p>
                        </div>
                    </div>

                    <!-- Rank 5 -->
                    <div class="bg-white/5 border border-white/5 p-6 rounded-[2rem] flex items-center justify-between hover:bg-white/10 transition px-10">
                        <div class="flex items-center space-x-6">
                            <div class="w-10 h-10 bg-gradient-to-br from-leader-pink to-leader-purple rounded-full flex items-center justify-center text-[10px] font-black italic">#5</div>
                            <div class="w-11 h-11 bg-primary rounded-full flex items-center justify-center font-black text-xs">RG</div>
                            <div>
                                <h4 class="text-sm font-black">Ramesh Gupta</h4>
                                <p class="text-[9px] text-gray-500 font-bold uppercase tracking-widest mt-0.5">Delhi</p>
                            </div>
                        </div>
                        <div class="text-right">
                             <p class="text-base font-black flex items-center justify-end">
                                 <i class="fas fa-coins text-[10px] text-gray-500 mr-2"></i>
                                 1,67,108
                             </p>
                        </div>
                    </div>
                </div>

                <!-- Bottom Info Bar -->
                <div class="info-bar p-7 rounded-[2.5rem] flex items-center space-x-8">
                    <div class="w-16 h-16 bg-[#ffc300] text-gray-900 rounded-full flex items-center justify-center text-3xl shadow-lg border-4 border-[#222336] shrink-0">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <div>
                        <h5 class="text-sm font-black uppercase tracking-[0.2em] text-yellow-500 mb-1">Coin System — Har Rupee Counts!</h5>
                        <p class="text-[10px] text-yellow-500/60 font-bold leading-relaxed">Jitna kharido utne coins milenge. ₹1 = 1 Coin • Coins ke hissab se rank upar-neeche hota hai</p>
                    </div>
                </div>

            </div>
        </div>

    </main>

    <footer class="py-12 border-t border-white/5 text-center mt-10 opacity-30">
        <p class="text-[9px] font-black uppercase tracking-[0.5em]">© 2026 BOLIBAZAR TECHNOLOGIES PVT LTD</p>
    </footer>

    <!-- Floating Global Alert (Bottom Right) -->
    <div class="fixed bottom-8 right-8 z-[200]">
        <div class="bg-[#1c1e2d] border border-white/10 p-4 rounded-2xl shadow-2xl flex items-center space-x-4 max-w-sm border-l-4 border-l-blue-500 animate-slide-in">
             <div class="w-10 h-10 bg-blue-500/20 text-blue-400 rounded-xl flex items-center justify-center text-lg">
                 <i class="fas fa-bell"></i>
             </div>
             <div>
                <p class="text-[10px] font-medium leading-tight">
                    🔥 <span class="text-white font-black">Toor Dal Premium 25kg</span> — price <span class="text-primary font-black tracking-tighter">₹4,697.57</span> ho gaya!
                </p>
             </div>
        </div>
    </div>

    <style>
        @keyframes slide-in {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .animate-slide-in { animation: slide-in 0.6s cubic-bezier(0.2, 0.8, 0.2, 1); }
    </style>

</body>
</html>
